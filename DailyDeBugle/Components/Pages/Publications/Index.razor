@page "/publications"
@attribute [Authorize(Policy = Policies.ManagePublications)]
@rendermode InteractiveServer
@inject DailyDeBugle.Services.IPublicationService PublicationService
@using DailyDeBugle.Models

<h3>Publications</h3>

<a class="btn btn-success mb-3" href="/publications/create">+ New Publication</a>

@if (publications == null)
{
    <p>Loading...</p>
}
else if (publications.Count == 0)
{
    <p>No publications found.</p>
}
else
{
    <table class="table table-striped">
        <thead>
        <tr>
            <th>Name</th>
            <th>Description</th>
            <th>Created</th>
            <th>Status</th>
            <th>Actions</th> 
        </tr>
        </thead>
        <tbody>
        @foreach (var pub in publications)
        {
            <tr>
                <td>@pub.Name</td>
                <td>@pub.Description</td>
                <td>@pub.CreatedDate.ToShortDateString()</td>
                <td>@(pub.IsActive ? "Active" : "Inactive")</td>
                <td>
                    <a href="/publications/edit/@pub.PublicationId" class="btn btn-primary btn-sm">Edit</a>
                    
                    <button class="btn btn-danger btn-sm" 
                            @onclick="() => ConfirmDelete(pub.PublicationId, pub.Name)">
                        Delete
                    </button>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

@if (publicationIdToDelete.HasValue)
{
    <div class="alert alert-warning mt-4 p-4" role="alert">
        <h4>Confirm Delete</h4>
        <p>
            Are you sure you want to delete the publication **"@publicationNameToDelete"**?
            This action will permanently delete all associated issues and articles.
        </p>
        <button class="btn btn-danger me-2" @onclick="DeletePublicationConfirmed">
            Yes, delete permanently
        </button>
        <button class="btn btn-secondary" @onclick="CancelDelete">
            Cancel
        </button>
    </div>
}


@code {
    private List<Publication>? publications;
    
    private int? publicationIdToDelete;
    private string? publicationNameToDelete;

    protected override async Task OnInitializedAsync()
    {
        publications = await PublicationService.GetPublicationsAsync();
    }

    private void ConfirmDelete(int publicationId, string publicationName)
    {
        publicationIdToDelete = publicationId;
        publicationNameToDelete = publicationName;
    }

    private void CancelDelete()
    {
        publicationIdToDelete = null;
        publicationNameToDelete = null;
    }

    private async Task DeletePublicationConfirmed()
    {
        if (publicationIdToDelete.HasValue)
        {
            await PublicationService.DeletePublicationAsync(publicationIdToDelete.Value);
            
            publications = await PublicationService.GetPublicationsAsync(); 
            
            publicationIdToDelete = null;
            publicationNameToDelete = null;
        }
    }
}