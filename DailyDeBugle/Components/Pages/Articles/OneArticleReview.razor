@page "/editor/review/{articleId:int}"
@rendermode InteractiveServer
@using DailyDeBugle.Models
@using DailyDeBugle.Services
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject IArticleService ArticleService
@inject IArticleLockService LockService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@implements IAsyncDisposable

<PageTitle>DailyDeBugle - Review: @article?.Headline</PageTitle>

@if (isLockedByOther)
{
    <div class="alert alert-danger">
        <h4>Статья недоступна для редактирования</h4>
        <p>Статья в данный момент редактируется пользователем <strong>@lockedByUserName</strong>.</p>
        <button class="btn btn-primary" @onclick="NavigateBack">← Вернуться к списку</button>
    </div>
}
else if (article == null)
{
    <p>Loading article...</p>
}
else
{
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-8">
                <!-- Информация о статье -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h4>@article.Headline</h4>
                        <div class="small text-muted">
                            By: @article.Author?.Username | 
                            Created: @article.CreatedDate.ToString("MMM dd, yyyy HH:mm") |
                            Status: <span class="badge bg-warning">@article.Status</span>
                        </div>
                    </div>
                </div>

                <!-- Редактор содержимого -->
                <div class="card">
                    <div class="card-header">
                        <h5>Article Content</h5>
                    </div>
                    <div class="card-body">
                        <textarea @bind="editedContent" class="form-control" rows="15" 
                                  placeholder="Article content..." disabled="@isLockedByOther"></textarea>
                        <div class="mt-2 text-muted small">
                            Characters: @editedContent.Length
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <!-- Панель действий редактора -->
                <div class="card">
                    <div class="card-header">
                        <h5>Editor Actions</h5>
                    </div>
                    <div class="card-body">
                        <!-- Одобрить -->
                        <div class="mb-3">
                            <button class="btn btn-success w-100" @onclick="ApproveArticle" disabled="@isProcessing">
                                ✅ Approve Article
                            </button>
                            <div class="form-text">Article will be locked and available for layout</div>
                        </div>

                        <!-- Отправить на доработку -->
                        <div class="mb-3">
                            <button class="btn btn-warning w-100" 
                                    @onclick="() => showRevisionModal = true" disabled="@isProcessing">
                                ✏️ Send for Revision
                            </button>
                            <div class="form-text">Author can make changes based on your comments</div>
                        </div>

                        <!-- Отклонить -->
                        <div class="mb-3">
                            <button class="btn btn-danger w-100" 
                                    @onclick="() => showRejectModal = true" disabled="@isProcessing">
                                ❌ Reject Article
                            </button>
                            <div class="form-text">Article will be archived with reason</div>
                        </div>

                        <!-- Навигация -->
                        <div class="mt-4">
                            <button class="btn btn-outline-secondary w-100" @onclick="NavigateBack">
                                ← Back to Review List
                            </button>
                        </div>
                    </div>
                </div>

                <!-- История комментариев -->
                @if (article.Comments?.Any() == true)
                {
                    <div class="card mt-4">
                        <div class="card-header">
                            <h6>Comments History</h6>
                        </div>
                        <div class="card-body">
                            @foreach (var comment in article.Comments.OrderByDescending(c => c.CreatedDate))
                            {
                                <div class="border-bottom pb-2 mb-2">
                                    <div class="small text-muted">
                                        @comment.CreatedDate.ToString("MMM dd, HH:mm")
                                        @if (comment.IsEditorComment)
                                        {
                                            <span class="badge bg-info">Editor</span>
                                        }
                                    </div>
                                    <div>@comment.Content</div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

<!-- Модальные окна без изменений -->

@code {
    [Parameter] public int ArticleId { get; set; }
    
    private Article? article;
    private string editedContent = string.Empty;
    private bool showRevisionModal = false;
    private bool showRejectModal = false;
    private string revisionComments = string.Empty;
    private string rejectionReason = string.Empty;
    private bool isProcessing = false;
    
    private int currentUserId;
    private bool isLockedByOther = false;
    private string? lockedByUserName;
    private bool lockAcquired = false;

    protected override async Task OnParametersSetAsync()
    {
        currentUserId = await GetCurrentUserIdAsync();
        article = await ArticleService.GetArticleAsync(ArticleId);
        if (article == null) return;

        editedContent = article.Content;

        // 1. Если статья заблокирована другим пользователем
        if (article.LockedByUserId.HasValue && article.LockedByUserId != currentUserId)
        {
            isLockedByOther = true;
            lockedByUserName = article.LockedByUser?.Username ?? "другим пользователем";
            return;
        }

        // 2. Пытаемся захватить (или продлить) блокировку
        var success = await LockService.TryLockArticleAsync(ArticleId, currentUserId);
        if (!success)
        {
            // Не удалось — значит кто-то перехватил
            isLockedByOther = true;
            var status = await LockService.GetLockStatusAsync(ArticleId);
            lockedByUserName = status.LockedByUserName ?? "другим пользователем";
        }
        else
        {
            lockAcquired = true;
            isLockedByOther = false;
        }
    }

    private async Task<int> GetCurrentUserIdAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userIdClaim = user.FindFirst("UserId")?.Value;
        return int.TryParse(userIdClaim, out var id) ? id : 0;
    }

    private async Task ApproveArticle()
    {
        if (article == null || isProcessing) return;
        isProcessing = true;
        try
        {
            var success = await ArticleService.ApproveArticleAsync(article.ArticleId, editedContent);
            if (success)
            {
                await ReleaseLock();
                Navigation.NavigateTo("/editor/review");
            }
        }
        finally
        {
            isProcessing = false;
        }
    }

    private async Task SendForRevision()
    {
        if (article == null || string.IsNullOrWhiteSpace(revisionComments) || isProcessing) return;
        isProcessing = true;
        try
        {
            var success = await ArticleService.SendForRevisionAsync(article.ArticleId, revisionComments);
            if (success)
            {
                await ReleaseLock();
                CloseModals();
                Navigation.NavigateTo("/editor/review");
            }
        }
        finally
        {
            isProcessing = false;
        }
    }

    private async Task RejectArticle()
    {
        if (article == null || string.IsNullOrWhiteSpace(rejectionReason) || isProcessing) return;
        isProcessing = true;
        try
        {
            var success = await ArticleService.RejectArticleAsync(article.ArticleId, rejectionReason);
            if (success)
            {
                await ReleaseLock();
                CloseModals();
                Navigation.NavigateTo("/editor/review");
            }
        }
        finally
        {
            isProcessing = false;
        }
    }

    private async Task ReleaseLock()
    {
        if (lockAcquired)
        {
            try
            {
                await LockService.UnlockArticleAsync(ArticleId, currentUserId);
            }
            catch { /* игнорируем */ }
            finally
            {
                lockAcquired = false;
            }
        }
    }

    private void CloseModals()
    {
        showRevisionModal = false;
        showRejectModal = false;
        revisionComments = string.Empty;
        rejectionReason = string.Empty;
    }

    private void NavigateBack()
    {
        Navigation.NavigateTo("/editor/review");
    }

    public async ValueTask DisposeAsync()
    {
        await ReleaseLock();
    }
}