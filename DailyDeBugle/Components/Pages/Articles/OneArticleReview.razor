    /// <summary>
    /// Применяет операцию к переданной строке (по ref).
    /// Используется для обновления localContent и serverContent.
    /// </summary>
    private static void ApplyOperationLocally(TextOperation op, ref string text)
    {
        try
        {
            if (op.Type == "insert" && !string.IsNullOrEmpty(op.Text))
            {
                if (op.Position >= 0 && op.Position <= text.Length)
                    text = text.Insert(op.Position, op.Text);
            }
            else if (op.Type == "delete" && op.Length > 0)
            {
                if (op.Position >= 0 && op.Position + op.Length <= text.Length)
                    text = text.Remove(op.Position, op.Length);
            }
            // noop — ничего
        }
        catch
        {
            // Игнорируем — при следующем DocumentLoaded синхронизируемся
        }
    }

