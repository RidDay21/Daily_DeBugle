    // ═════════════════════════════════════════════════════════════════════════

    /// <summary>
    /// Вычисляет минимальный набор операций (delete + insert) для преобразования
    /// oldText → newText. Алгоритм: найти общий префикс и суффикс, остаток — это
    /// удалённый/вставленный фрагмент. Работает корректно при любом количестве
    /// изменений в одном месте (вставка, удаление, замена, Ctrl+A Delete).
    /// </summary>
    private static List<TextOperation> ComputeOperations(string oldText, string newText)
    {
        var ops = new List<TextOperation>(2);

        // Общий префикс
        int prefix = 0;
        int minLen = Math.Min(oldText.Length, newText.Length);
        while (prefix < minLen && oldText[prefix] == newText[prefix])
            prefix++;

        // Общий суффикс (не заходя за префикс с обеих сторон)
        int oldEnd = oldText.Length;
        int newEnd = newText.Length;
        while (oldEnd > prefix && newEnd > prefix
               && oldText[oldEnd - 1] == newText[newEnd - 1])
        {
            oldEnd--;
            newEnd--;
        }

        int deleteLen = oldEnd - prefix;   // сколько символов удаляется
        int insertLen = newEnd - prefix;   // сколько символов вставляется

        // Сначала удаление, потом вставка — в ту же позицию.
        // Порядок важен: если применять в обратном порядке, позиция съедется.
        if (deleteLen > 0)
            ops.Add(new TextOperation { Type = "delete", Position = prefix, Length = deleteLen });

        if (insertLen > 0)
            ops.Add(new TextOperation
            {
                Type = "insert",
                Position = prefix,
                Text = newText.Substring(prefix, insertLen)
            });

        return ops;
    }

