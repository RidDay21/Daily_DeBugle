@page "/articles"
@attribute [Authorize(Policy = Policies.WriteArticles)]
@rendermode InteractiveServer

@inject DailyDeBugle.Services.IArticleService ArticleService
@inject AuthenticationStateProvider AuthenticationStateProvider

@using DailyDeBugle.Models
@using DailyDeBugle.Security
@using DailyDeBugle.Services
@using Microsoft.AspNetCore.Components.Authorization

<h3>Articles</h3>

<a class="btn btn-success mb-3" href="/articles/create">+ New Article</a>

@if (articles == null)
{
    <p>Loading...</p>
}
else if (articles.Count == 0)
{
    <p>No articles yet.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Headline</th>
                <th>Author</th>
                <th>Issue</th>
                <th>Date</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var article in articles)
            {
                <tr>
                    <td>@article.Headline</td>

                    <td>@article.Author?.Username</td>

                    <td>
                        @if (article.Issue != null)
                        {
                            <span>Issue @article.Issue.IssueNumber</span>
                        }
                        else
                        {
                            <span class="text-muted">No issue</span>
                        }
                    </td>

                    <td>@article.CreatedDate.ToShortDateString()</td>

                    <td>
                        <span class="badge @GetStatusBadgeClass(article.Status)">
                            @article.Status
                        </span>
                    </td>

                    <td>
                        @if (CanEditArticle(article))
                        {
                            @if (article.Status != ArticleStatus.Approved)
                            {
                                <a class="btn btn-outline-primary btn-sm me-1"
                                   href="/editor/review">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                            }

                            <button class="btn btn-danger btn-sm"
                                    @onclick="() => ConfirmDelete(article.ArticleId, article.Headline)">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (articleIdToDelete.HasValue)
{
    <div class="alert alert-warning mt-4 p-4" role="alert">
        <h4>Confirm Delete</h4>

        <p>
            Are you sure you want to delete the article
            <strong>"@articleHeadlineToDelete"</strong>?
        </p>

        <div class="d-flex gap-2">
            <button class="btn btn-danger" @onclick="DeleteArticleConfirmed">
                Yes, delete
            </button>

            <button class="btn btn-secondary" @onclick="CancelDelete">
                Cancel
            </button>
        </div>
    </div>
}

@code {

    private List<Article>? articles;
    private System.Security.Claims.ClaimsPrincipal? currentUser;

    private int? articleIdToDelete;
    private string? articleHeadlineToDelete;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        currentUser = auth.User;

        await LoadArticles();
    }

    private bool CanEditArticle(Article article)
        => currentUser != null &&
           ArticleAccessRules.CanEditArticleContent(currentUser, article);

    private async Task LoadArticles()
    {
        articles = await ArticleService.GetArticlesAsync();
    }

    private void ConfirmDelete(int articleId, string articleHeadline)
    {
        articleIdToDelete = articleId;
        articleHeadlineToDelete = articleHeadline;
    }

    private void CancelDelete()
    {
        articleIdToDelete = null;
        articleHeadlineToDelete = null;
    }

    private async Task DeleteArticleConfirmed()
    {
        if (articleIdToDelete.HasValue)
        {
            await ArticleService.DeleteArticleAsync(articleIdToDelete.Value);
            await LoadArticles();

            articleIdToDelete = null;
            articleHeadlineToDelete = null;
        }
    }

    private string GetStatusBadgeClass(ArticleStatus status)
    {
        return status switch
        {
            ArticleStatus.Draft => "bg-secondary",
            ArticleStatus.UnderReview => "bg-info",
            ArticleStatus.RequiresRevision => "bg-warning",
            ArticleStatus.Approved => "bg-primary",
            ArticleStatus.Rejected => "bg-danger",
            _ => "bg-secondary"
        };
    }

}