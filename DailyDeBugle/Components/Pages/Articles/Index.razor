@page "/articles"
@rendermode InteractiveServer
@using DailyDeBugle.Models
@using DailyDeBugle.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject IArticleService ArticleService
@inject IArticleLockService LockService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<h3>Articles</h3>

<a class="btn btn-success mb-3" href="/articles/create">+ New Article</a>

@if (articles == null)
{
    <p>Loading...</p>
}
else if (articles.Count == 0)
{
    <p>No articles yet.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Headline</th>
                <th>Author</th>
                <th>Issue</th>
                <th>Date</th>
                <th>Status</th>
                <th>Editing</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var article in articles)
            {
                <tr>
                    <td>@article.Headline</td>
                    <td>@article.Author?.Username</td>
                    <td>
                        @if (article.Issue != null)
                        {
                            <span>Issue @article.Issue.IssueNumber</span>
                        }
                        else
                        {
                            <span class="text-muted">No issue</span>
                        }
                    </td>
                    <td>@article.CreatedDate.ToShortDateString()</td>
                    <td>
                        <span class="badge @GetStatusBadgeClass(article.Status)">
                            @article.Status
                        </span>
                    </td>
                    <td>
                        @if (article.IsLocked)
                        {
                            <span class="badge bg-warning text-dark" title="Редактирует @(article.LockedByUser?.Username ?? "неизвестный")">
                                <i class="bi bi-lock-fill"></i> Занято
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-success">Свободно</span>
                        }
                    </td>
                    <td>
                        @if (!article.IsLocked || article.LockedByUserId == currentUserId)
                        {
                            @if (article.Status != ArticleStatus.Approved)
                            {
                                <a class="btn btn-outline-primary btn-sm me-1" href="/articles/review/@article.ArticleId">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                            }
                        }
                        else
                        {
                            <button class="btn btn-outline-secondary btn-sm me-1" disabled 
                                    title="Статья редактируется другим пользователем">
                                <i class="bi bi-pencil"></i> Edit
                            </button>
                        }
                        <button class="btn btn-danger btn-sm"
                                @onclick="() => ConfirmDelete(article.ArticleId, article.Headline)">
                            <i class="bi bi-trash"></i> Delete
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (articleIdToDelete.HasValue)
{
    <div class="alert alert-warning mt-4 p-4" role="alert">
        <h4>Подтвердите удаление</h4>
        <p>
            Вы уверены, что хотите удалить статью <strong>"@articleHeadlineToDelete"</strong>?
        </p>
        <div class="d-flex gap-2">
            <button class="btn btn-danger" @onclick="DeleteArticleConfirmed">
                Да, удалить
            </button>
            <button class="btn btn-secondary" @onclick="CancelDelete">
                Отмена
            </button>
        </div>
    </div>
}

@code {
    private List<Article>? articles;
    private int? articleIdToDelete;
    private string? articleHeadlineToDelete;
    private int currentUserId;

    protected override async Task OnInitializedAsync()
    {
        currentUserId = await GetCurrentUserIdAsync();
        await LoadArticles();
    }

    private async Task<int> GetCurrentUserIdAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userIdClaim = user.FindFirst("UserId")?.Value;
        return int.TryParse(userIdClaim, out var id) ? id : 0;
    }

    private async Task LoadArticles()
    {
        articles = await ArticleService.GetArticlesAsync();
    }

    private void ConfirmDelete(int articleId, string articleHeadline)
    {
        articleIdToDelete = articleId;
        articleHeadlineToDelete = articleHeadline;
    }

    private void CancelDelete()
    {
        articleIdToDelete = null;
        articleHeadlineToDelete = null;
    }

    private async Task DeleteArticleConfirmed()
    {
        if (articleIdToDelete.HasValue)
        {
            await ArticleService.DeleteArticleAsync(articleIdToDelete.Value);
            await LoadArticles();
            articleIdToDelete = null;
            articleHeadlineToDelete = null;
        }
    }

    private string GetStatusBadgeClass(ArticleStatus status)
    {
        return status switch
        {
            ArticleStatus.Draft => "bg-secondary",
            ArticleStatus.UnderReview => "bg-info",
            ArticleStatus.RequiresRevision => "bg-warning",
            ArticleStatus.Approved => "bg-primary",
            ArticleStatus.Rejected => "bg-danger",
            _ => "bg-secondary"
        };
    }
}