@page "/editor/review"
@rendermode InteractiveServer
@using DailyDeBugle.Models
@using DailyDeBugle.Services
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.SignalR.Client
@using System.Security.Claims
@implements IAsyncDisposable
@inject IArticleService ArticleService
@inject IArticleLockService LockService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<PageTitle>DailyDeBugle - Review Articles</PageTitle>

<h3>Article Review Dashboard</h3>

@if (currentUserId == 0)
{
    <div class="alert alert-warning">Загрузка данных пользователя...</div>
}
else
{
    <ul class="nav nav-tabs mb-4">
        <li class="nav-item">
            <button class="nav-link @(activeTab == "underReview" ? "active" : "")"
                    @onclick="@(() => SwitchTab("underReview"))">
                Under Review
                @if (underReviewCount > 0)
                {
                    <span class="badge bg-danger ms-1">@underReviewCount</span>
                }
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "drafts" ? "active" : "")"
                    @onclick="@(() => SwitchTab("drafts"))">
                Drafts
                @if (draftsCount > 0)
                {
                    <span class="badge bg-warning ms-1">@draftsCount</span>
                }
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "all" ? "active" : "")"
                    @onclick="@(() => SwitchTab("all"))">
                All Articles
                <span class="badge bg-secondary ms-1">@allCount</span>
            </button>
        </li>
    </ul>

    @if (articles == null)
    {
        <p>Loading articles...</p>
    }
    else if (!articles.Any())
    {
        <div class="alert alert-info">
            <h5>No articles found</h5>
            <p>There are currently no articles with status "@GetTabStatus()".</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Headline</th>
                        <th>Author</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th>Issue</th>
                        <th>Editing</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var article in articles)
                    {
                        <tr>
                            <td>
                                <strong>@article.Headline</strong>
                                <div class="text-muted small">
                                    @GetPreview(article.Content)
                                </div>
                            </td>
                            <td>@(article.Author?.Username ?? "Unknown")</td>
                            <td>
                                <span class="badge @GetStatusBadgeClass(article.Status)">
                                    @article.Status
                                </span>
                            </td>
                            <td>@article.CreatedDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                @if (article.Issue != null)
                                {
                                    <small>Issue #@article.Issue.IssueNumber</small>
                                }
                                else
                                {
                                    <span class="text-muted">No issue</span>
                                }
                            </td>
                            <td>
                                @if (article.IsLocked)
                                {
                                    <span class="badge bg-warning text-dark" title="Редактирует @(article.LockedByUser?.Username ?? "неизвестный")">
                                        <i class="bi bi-lock-fill"></i> Занято
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Свободно</span>
                                }
                            </td>
                            <td>
                                @if (article.Status == ArticleStatus.UnderReview || article.Status == ArticleStatus.RequiresRevision)
                                {
                                    @if (article.IsLocked && article.LockedByUserId != currentUserId)
                                    {
                                        <button class="btn btn-primary btn-sm" disabled
                                                title="Статья редактируется @(article.LockedByUser?.Username ?? "другим пользователем")">
                                            Review
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-primary btn-sm"
                                                @onclick="@(() => TryReviewArticle(article))">
                                            Review
                                        </button>
                                    }
                                }
                                @if (article.Status == ArticleStatus.Draft)
                                {
                                    <button class="btn btn-outline-primary btn-sm"
                                            @onclick="@(() => SendToReview(article))">
                                        Send to Review
                                    </button>
                                }
                                <a class="btn btn-outline-info btn-sm" href="/articles/edit/@article.ArticleId">
                                    View
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-info mt-3">@message</div>
}

@code {
    private List<Article> articles = new();
    private List<Article> allArticles = new();
    private HubConnection? hubConnection;
    private string activeTab = "underReview";
    private string message = string.Empty;
    private int currentUserId;

    private int underReviewCount = 0;
    private int draftsCount = 0;
    private int allCount = 0;

    protected override async Task OnInitializedAsync()
    {
        currentUserId = await GetCurrentUserIdAsync();
        if (currentUserId == 0)
        {
            Navigation.NavigateTo("/login");
            return;
        }
        await LoadAllArticles();
        SwitchTab("underReview");
        await InitializeSignalR();
    }

    private async Task InitializeSignalR()
    {
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/collaborationhub"))
            .Build();

        hubConnection.On<int, bool, string>("ArticleLockChanged", async (articleId, isLocked, userName) =>
        {
            // Просто перезагружаем список из БД, чтобы гарантировать консистентность
            await LoadAllArticles();
            SwitchTab(activeTab);
            StateHasChanged();
        });

        await hubConnection.StartAsync();

        foreach (var article in allArticles)
        {
            await hubConnection.InvokeAsync("JoinArticleGroup", article.ArticleId);
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection != null)
        {
            foreach (var article in allArticles)
            {
                await hubConnection.InvokeAsync("LeaveArticleGroup", article.ArticleId);
            }
            await hubConnection.DisposeAsync();
        }
    }

    private async Task<int> GetCurrentUserIdAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userIdClaim = user.FindFirst("UserId")?.Value;
        return int.TryParse(userIdClaim, out var id) ? id : 0;
    }

    private async Task LoadAllArticles()
    {
        allArticles = await ArticleService.GetAllArticlesAsync();
        underReviewCount = allArticles.Count(a => a.Status == ArticleStatus.UnderReview);
        draftsCount = allArticles.Count(a => a.Status == ArticleStatus.Draft);
        allCount = allArticles.Count;
    }

    private void SwitchTab(string tab)
    {
        activeTab = tab;
        if (allArticles == null) return;
        articles = activeTab switch
        {
            "underReview" => allArticles.Where(a => a.Status == ArticleStatus.UnderReview).ToList(),
            "drafts" => allArticles.Where(a => a.Status == ArticleStatus.Draft).ToList(),
            "all" => allArticles.ToList(),
            _ => allArticles.Where(a => a.Status == ArticleStatus.UnderReview).ToList()
        };
        StateHasChanged();
    }

    private async Task TryReviewArticle(Article article)
    {
        var success = await LockService.TryLockArticleAsync(article.ArticleId, currentUserId);
        if (success)
        {
            Navigation.NavigateTo($"/editor/review/{article.ArticleId}");
        }
        else
        {
            message = $"Не удалось заблокировать статью «{article.Headline}». Возможно, её уже редактируют.";
            await LoadAllArticles();
            SwitchTab(activeTab);
        }
    }

    private async Task SendToReview(Article article)
    {
        try
        {
            article.Status = ArticleStatus.UnderReview;
            article.ModifiedDate = DateTime.UtcNow;
            await ArticleService.UpdateArticleAsync(article);
            await LoadAllArticles();
            SwitchTab(activeTab);
            message = $"Article '{article.Headline}' sent to review successfully!";
        }
        catch (Exception ex)
        {
            message = $"Error sending article to review: {ex.Message}";
        }
    }

    private string GetTabStatus() => activeTab switch
    {
        "underReview" => "Under Review",
        "drafts" => "Draft",
        "all" => "All Articles",
        _ => "Under Review"
    };

    private string GetPreview(string content) =>
        string.IsNullOrEmpty(content) ? "No content" : content.Length > 100 ? content.Substring(0, 100) + "..." : content;

    private string GetStatusBadgeClass(ArticleStatus status) => status switch
    {
        ArticleStatus.Approved => "bg-success",
        ArticleStatus.UnderReview => "bg-info",
        ArticleStatus.RequiresRevision => "bg-warning",
        ArticleStatus.Draft => "bg-secondary",
        ArticleStatus.Rejected => "bg-danger",
        _ => "bg-secondary"
    };
}