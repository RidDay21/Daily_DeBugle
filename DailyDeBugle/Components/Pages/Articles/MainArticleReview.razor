    private async Task InitSignalR()
    {
        _hub = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/editinghub"))
            .WithAutomaticReconnect()
            .Build();

        // ── Обновление редакторов для конкретной статьи ──
        _hub.On<int, IEnumerable<string>>("ActiveEditorsUpdate", (articleId, names) =>
        {
            activeEditorsByArticle[articleId] = names.ToList();
            InvokeAsync(StateHasChanged);
        });

        // ── Статья финализирована — перезагружаем список ──
        _hub.On<int>("ArticleFinalized", async (articleId) =>
        {
            await LoadAllArticles();
            SwitchTab(activeTab);
            await InvokeAsync(StateHasChanged);
        });

        // ── Изменение блокировки (совместимость с CollaborationHub) ──
        _hub.On<int, bool, string>("ArticleLockChanged", async (articleId, isLocked, userName) =>
        {
            await LoadAllArticles();
            SwitchTab(activeTab);
            await InvokeAsync(StateHasChanged);
        });

        _hub.Reconnected += async _ =>
        {
            // При переподключении заново подписываемся на dashboard-группу
            if (_hub.State == HubConnectionState.Connected)
                await _hub.InvokeAsync("JoinDashboard");
        };

        await _hub.StartAsync();

        // Подписываемся на review-dashboard группу (EditingHub рассылает туда ActiveEditorsUpdate)
        await _hub.InvokeAsync("JoinDashboard");
    }

    // ═════════════════════════════════════════════════════════════════════════
    // Вспомогательные методы
    // ═════════════════════════════════════════════════════════════════════════

    private List<string> GetEditors(int articleId)
    {
        return activeEditorsByArticle.TryGetValue(articleId, out var list) ? list : new List<string>();
    }

    private async Task<int> GetCurrentUserIdAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userIdClaim = authState.User.FindFirst("UserId")?.Value;
        return int.TryParse(userIdClaim, out var id) ? id : 0;
    }

    private bool CanEditArticle(Article article) =>
        currentUser != null && ArticleAccessRules.CanEditArticleContent(currentUser, article);

    private async Task LoadAllArticles()
    {
        allArticles = await ArticleService.GetAllArticlesAsync();
        underReviewCount = allArticles.Count(a => a.Status == ArticleStatus.UnderReview);
        draftsCount = allArticles.Count(a => a.Status == ArticleStatus.Draft);
        allCount = allArticles.Count;
    }

    private void SwitchTab(string tab)
    {
        activeTab = tab;
        articles = activeTab switch
        {
            "underReview" => allArticles.Where(a => a.Status == ArticleStatus.UnderReview).ToList(),
            "drafts" => allArticles.Where(a => a.Status == ArticleStatus.Draft).ToList(),
            "all" => allArticles.ToList(),
            _ => allArticles.Where(a => a.Status == ArticleStatus.UnderReview).ToList()
        };
        StateHasChanged();
    }

    private async Task SendToReview(Article article)
    {
        try
        {
            article.Status = ArticleStatus.UnderReview;
            article.ModifiedDate = DateTime.UtcNow;
            await ArticleService.UpdateArticleAsync(article);
            await LoadAllArticles();
            SwitchTab(activeTab);
            message = $"Article '{article.Headline}' sent to review successfully!";
        }
        catch (Exception ex)
        {
            message = $"Error sending article to review: {ex.Message}";
        }
    }

    private string GetTabStatus() => activeTab switch
    {
        "underReview" => "Under Review",
        "drafts" => "Draft",
        "all" => "All Articles",
        _ => "Under Review"
    };

    private static string GetPreview(string content) =>
        string.IsNullOrEmpty(content) ? "No content"
        : content.Length > 100 ? content[..100] + "..."
        : content;

    private static string GetStatusBadgeClass(ArticleStatus status) => status switch
    {
        ArticleStatus.Approved => "bg-success",
        ArticleStatus.UnderReview => "bg-info text-dark",
        ArticleStatus.RequiresRevision => "bg-warning text-dark",
        ArticleStatus.Draft => "bg-secondary",
        ArticleStatus.Rejected => "bg-danger",
        _ => "bg-secondary"
    };

    // ═════════════════════════════════════════════════════════════════════════
    // IAsyncDisposable
    // ═════════════════════════════════════════════════════════════════════════

    public async ValueTask DisposeAsync()
    {
        if (_hub != null)
        {
            try
            {
                if (_hub.State == HubConnectionState.Connected)
                    await _hub.InvokeAsync("LeaveDashboard");
            }
            catch { }
            await _hub.DisposeAsync();
        }
    }
}
