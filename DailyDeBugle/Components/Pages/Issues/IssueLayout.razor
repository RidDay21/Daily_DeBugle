@code {
    [Parameter]
    public int issueId { get; set; }

    private Issue currentIssue;
    private List<Article> allArticles = new();
    private List<Article> filteredArticles = new();
    private List<PageLayout> pageLayouts = new();
    private List<Template> templates = new();
    private PageLayout currentPageLayout;
    private GlobalTextStyle currentTextStyle;
    private int? selectedTemplateId;
    private List<string> conflicts = new();
    private int currentPageNumber = 1;
    private bool showOnlyApproved = false;
    
    // Константы для размеров страницы (А4)
    private const double PAGE_WIDTH = 21.0;    // см, ширина страницы А4
    private const double PAGE_HEIGHT = 29.7;   // см, высота страницы А4
    private const double MIN_MARGIN = 0.5;     // минимальный отступ
    private const double MAX_MARGIN = 5.0;     // максимальный отступ
    private const double MIN_COLUMN_WIDTH = 4.0; // минимальная ширина колонки
    private const double MAX_COLUMN_GAP = 2.0;  // максимальный промежуток между колонками
    
    // Ошибки валидации макета
    private List<string> layoutErrors = new();
    private string? notificationMessage = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }
    
    private void NavigateToIssuesList()
    {
        Navigation.NavigateTo("/issues");
    }
    
    private void NavigateToPreview()
    {
        Navigation.NavigateTo($"/issues/{issueId}/preview");
    }

    private async Task LoadData()
    {
        try
        {
            currentIssue = await IssueService.GetIssueAsync(issueId);
            
            if (currentIssue != null)
            {
                allArticles = await ArticleService.GetArticlesByIssueAsync(issueId);
                pageLayouts = await LayoutService.GetPageLayoutsForIssueAsync(issueId);
                templates = await TemplateService.GetTemplatesAsync();
                currentTextStyle = await TextStyleService.GetStylesForIssueAsync(issueId);
                
                UpdateFilteredArticles();
                await LoadCurrentPageLayout();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки данных: {ex.Message}");
        }
    }

    private async Task LoadCurrentPageLayout()
    {
        currentPageLayout = pageLayouts.FirstOrDefault(p => p.PageNumber == currentPageNumber);
        if (currentPageLayout != null)
        {
            selectedTemplateId = currentPageLayout.TemplateId;
        }
        conflicts.Clear();
        StateHasChanged();
    }

    private void UpdateFilteredArticles()
    {
        filteredArticles = showOnlyApproved
            ? allArticles.Where(a => a.Status == ArticleStatus.Approved).ToList()
            : allArticles.ToList();
    }

    private async Task SwitchToPage(int pageNumber)
    {
        currentPageNumber = pageNumber;
        await LoadCurrentPageLayout();
    }
    
    private double GetColumnWidth()
    {
        return GetColumnWidth(currentPageLayout);
    }

    private double GetColumnWidth(PageLayout pageLayout)
    {
        if (pageLayout == null || pageLayout.ColumnCount == 0) 
            return 0;
    
        double totalGaps = (pageLayout.ColumnCount - 1) * pageLayout.ColumnGap;
        double availableWidth = pageLayout.TextAreaWidth - totalGaps;
        return availableWidth / pageLayout.ColumnCount;
    }

    private void AdjustColumnsLayout()
    {
        AdjustColumnsLayout(currentPageLayout);
    }

    private void AdjustColumnsLayout(PageLayout layout)
    {
        if (layout == null) return;
    
        // Фиксированные отступы
        layout.MarginTop = 2.0;
        layout.MarginBottom = 2.0;
        layout.MarginLeft = 2.0;
        layout.MarginRight = 2.0;
    
        // Текстовая область занимает все пространство между отступами
        layout.TextAreaWidth = PAGE_WIDTH - layout.MarginLeft - layout.MarginRight;
        layout.TextAreaHeight = PAGE_HEIGHT - layout.MarginTop - layout.MarginBottom;
    
        // Настраиваем промежутки между колонками
        switch (layout.ColumnCount)
        {
            case 1:
                layout.ColumnGap = 0;
                break;
            case 2:
                layout.ColumnGap = 1.0;
                break;
            case 3:
                layout.ColumnGap = 0.7;
                break;
            case 4:
                layout.ColumnGap = 0.5;
                break;
        }
    
        // Округляем значения
        layout.TextAreaWidth = Math.Round(layout.TextAreaWidth, 1);
        layout.TextAreaHeight = Math.Round(layout.TextAreaHeight, 1);
        layout.ColumnGap = Math.Round(layout.ColumnGap, 1);
    
        ValidateLayout(layout);
    }
    
    private async Task NextPage()
    {
        currentPageNumber++;
        await LoadCurrentPageLayout();
    }

    private async Task PrevPage()
    {
        if (currentPageNumber > 1)
        {
            currentPageNumber--;
            await LoadCurrentPageLayout();
        }
    }

    private async Task InitializePageLayout()
    {
        var newPageLayout = new PageLayout
        {
            IssueId = issueId,
            PageNumber = currentPageNumber,
            LayoutSettings = "{}",
            LayoutElements = new List<LayoutElement>(),
            CreatedAt = DateTime.UtcNow,
            UpdatedAt = DateTime.UtcNow,
            ColumnCount = 2
        };
    
        // Применяем автоматическую настройку колонок
        AdjustColumnsLayout(newPageLayout);
    
        await LayoutService.CreateOrUpdatePageLayoutAsync(newPageLayout);
        await LoadData();
    }

    // ТОЧНЫЙ расчет высоты статьи с учетом типографики
    private double CalculateArticleHeight(Article article)
    {
        if (article == null || string.IsNullOrEmpty(article.Content)) 
            return 3.0; // Минимальная высота
        
        // Параметры типографики
        double fontSize = currentTextStyle?.BodySize ?? 14.0; // pt
        double lineSpacing = currentTextStyle?.BodyLineSpacing ?? 1.4;
        string fontFamily = currentTextStyle?.PrimaryFont ?? "'Times New Roman', serif";
        
        // Ширина колонки в см
        double columnWidth = currentPageLayout != null 
            ? GetColumnWidth(currentPageLayout) 
            : 8.0; // Примерная ширина по умолчанию
        
        // Коэффициенты для разных шрифтов
        double fontWidthFactor = GetFontWidthFactor(fontFamily);
        
        // Базовые метрики для Times New Roman 14pt
        double baseCharWidth = 0.28; // см на символ для 14pt Times New Roman
        double baseLineHeight = 0.45; // см на строку для 14pt с межстрочным интервалом 1.4
        
        // Корректировка на шрифт и размер
        double charWidth = baseCharWidth * (fontSize / 14.0) * fontWidthFactor;
        double lineHeight = baseLineHeight * (fontSize / 14.0) * (lineSpacing / 1.4);
        
        // Количество символов в строке (округление в меньшую сторону)
        int charsPerLine = Math.Max(1, (int)(columnWidth / charWidth));
        
        // Количество строк в содержании
        int contentLines = (int)Math.Ceiling((double)article.Content.Length / charsPerLine);
        
        // Учитываем:
        // 1. Заголовок статьи (примерно 2 строки)
        // 2. Метаданные (автор, дата) - 1 строка
        // 3. Отступы сверху и снизу статьи (0.5 см каждый = примерно 1 строка)
        // 4. Отступы между абзацами (примерно 5 абзацев по 0.2 см = 1 строка)
        
        int totalLines = contentLines + 2 + 1 + 1 + 1; // +5 дополнительных строк
        
        // Общая высота в см
        double totalHeight = totalLines * lineHeight;
        
        // Минимальная и максимальная высота
        double minHeight = 3.0;
        double maxHeight = PAGE_HEIGHT - 4.0; // Минус отступы
        
        return Math.Round(Math.Max(minHeight, Math.Min(totalHeight, maxHeight)), 1);
    }

    // Коэффициенты ширины для разных шрифтов
    private double GetFontWidthFactor(string fontFamily)
    {
        if (fontFamily.Contains("Arial") || fontFamily.Contains("Helvetica"))
            return 0.95; // Уже
        if (fontFamily.Contains("Georgia"))
            return 1.05; // Шире
        if (fontFamily.Contains("Courier") || fontFamily.Contains("monospace"))
            return 1.2; // Намного шире
        return 1.0; // Times New Roman - базовая
    }

    // Получить занятую высоту на странице
    private double GetOccupiedHeightOnPage(PageLayout pageLayout)
    {
        if (pageLayout == null || !pageLayout.LayoutElements.Any())
            return 0.5; // Базовый отступ сверху
        
        double maxBottom = 0;
        
        foreach (var element in pageLayout.LayoutElements)
        {
            var position = GetElementPosition(element);
            var size = GetElementSize(element);
            
            double elementBottom = position.Y + size.Height;
            if (elementBottom > maxBottom)
            {
                maxBottom = elementBottom;
            }
        }
        
        // Добавляем отступ между элементами
        return maxBottom + 0.3;
    }

    // Получить доступную высоту на странице
    private double GetAvailableHeightOnPage()
    {
        if (currentPageLayout == null) return 0;
        
        double occupiedHeight = GetOccupiedHeightOnPage(currentPageLayout);
        double availableHeight = currentPageLayout.TextAreaHeight - occupiedHeight - 1.0; // -1.0 для нижнего отступа
        
        return Math.Max(0, Math.Round(availableHeight, 1));
    }

    // ОСНОВНОЙ МЕТОД: Размещение статьи на странице с проверкой
    private async Task HandlePlaceArticle(Article article)
    {
        if (article == null || currentPageLayout == null) return;
        
        // Рассчитываем точную высоту статьи
        double articleHeight = CalculateArticleHeight(article);
        
        // Получаем доступную высоту на странице
        double availableHeight = GetAvailableHeightOnPage();
        
        // Проверяем, помещается ли статья
        if (articleHeight <= availableHeight)
        {
            // Находим позицию для новой статьи (внизу существующих элементов)
            double yPosition = GetOccupiedHeightOnPage(currentPageLayout);
            
            // Размещаем статью
            double columnWidth = GetColumnWidth(currentPageLayout);
            double x = 0; // Первая колонка
            var position = JsonSerializer.Serialize(new { X = x, Y = yPosition });
            var size = JsonSerializer.Serialize(new { Width = columnWidth, Height = articleHeight });
            
            await LayoutService.AddArticleToLayoutAsync(
                currentPageLayout.PageLayoutId, 
                article.ArticleId, 
                position, 
                size
            );
            
            await LoadData();
            ShowNotification($"Статья \"{article.Headline}\" размещена на странице {currentPageLayout.PageNumber}");
        }
        else
        {
            // Статья не помещается - показываем сообщение
            ShowNotification($"Статья \"{article.Headline}\" не помещается на страницу. Требуется: {articleHeight:F1} см, доступно: {availableHeight:F1} см. Создайте новую страницу.");
        }
    }

    // Получить элементы в колонке
    private List<LayoutElement> GetElementsInColumn(PageLayout pageLayout, int columnIndex)
    {
        var elements = new List<LayoutElement>();
    
        if (pageLayout == null || pageLayout.ColumnCount == 0) return elements;
    
        double columnWidth = GetColumnWidth(pageLayout);
        double columnSpacing = columnWidth + pageLayout.ColumnGap;
    
        foreach (var element in pageLayout.LayoutElements)
        {
            var position = GetElementPosition(element);
        
            int elementColumn = (int)(position.X / columnSpacing);
        
            if (elementColumn == columnIndex)
            {
                elements.Add(element);
            }
        }
    
        return elements.OrderBy(e => GetElementPosition(e).Y).ToList();
    }

    private (double X, double Y) GetElementPosition(LayoutElement element)
    {
        try
        {
            if (!string.IsNullOrEmpty(element.Position))
            {
                var position = JsonSerializer.Deserialize<Dictionary<string, double>>(element.Position);
                if (position != null)
                {
                    double x = position.ContainsKey("X") ? position["X"] : 0;
                    double y = position.ContainsKey("Y") ? position["Y"] : 0;
                    return (x, y);
                }
            }
        }
        catch
        {
            // Игнорируем ошибки парсинга
        }
    
        return (0, 0);
    }

    private (double Width, double Height) GetElementSize(LayoutElement element)
    {
        try
        {
            if (!string.IsNullOrEmpty(element.Size))
            {
                var size = JsonSerializer.Deserialize<Dictionary<string, double>>(element.Size);
                if (size != null && size.ContainsKey("Width") && size.ContainsKey("Height"))
                {
                    return (size["Width"], size["Height"]);
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка парсинга размера: {ex.Message}");
        }
    
        double columnWidth = currentPageLayout?.TextAreaWidth / currentPageLayout?.ColumnCount ?? 5.0;
        return (columnWidth, 3.0);
    }

    // Проверить и исправить переполнение страниц
    private async Task CheckAndFixOverflow()
    {
        ShowNotification("Функция проверки переполнения отключена. Статьи теперь не добавляются, если не помещаются на страницу.");
    }

    private void ValidateLayout(PageLayout layout)
    {
        layoutErrors.Clear();
    
        if (layout == null) return;
    
        double totalWidth = layout.MarginLeft + layout.TextAreaWidth + layout.MarginRight;
        if (totalWidth > PAGE_WIDTH)
        {
            layoutErrors.Add($"Суммарная ширина ({totalWidth:F1} см) превышает ширину страницы ({PAGE_WIDTH} см)");
        }
    
        double totalHeight = layout.MarginTop + layout.TextAreaHeight + layout.MarginBottom;
        if (totalHeight > PAGE_HEIGHT)
        {
            layoutErrors.Add($"Суммарная высота ({totalHeight:F1} см) превышает высоту страницы ({PAGE_HEIGHT} см)");
        }
    
        double columnWidth = GetColumnWidth(layout);
        if (columnWidth < MIN_COLUMN_WIDTH)
        {
            layoutErrors.Add($"Ширина колонки ({columnWidth:F1} см) слишком мала (минимум {MIN_COLUMN_WIDTH} см)");
        }
    }

    // Методы для уведомлений
    private void ShowNotification(string message)
    {
        notificationMessage = message;
        StateHasChanged();
        
        // Автоматически скрыть уведомление через 5 секунд
        _ = AutoDismissNotification();
    }

    private async Task AutoDismissNotification()
    {
        await Task.Delay(5000);
        notificationMessage = null;
        await InvokeAsync(StateHasChanged);
    }

    private void DismissNotification()
    {
        notificationMessage = null;
        StateHasChanged();
    }

    // Остальные методы
    private async Task SaveLayoutConfig()
    {
        if (currentPageLayout != null)
        {
            currentPageLayout.TemplateId = selectedTemplateId ?? 0;
            await LayoutService.CreateOrUpdatePageLayoutAsync(currentPageLayout);
            await LoadData();
            ShowNotification("Настройки страницы сохранены.");
        }
    }

    private async Task HandleAddPage()
    {
        var newPageNumber = pageLayouts.Count + 1;
        var newPageLayout = new PageLayout
        {
            IssueId = issueId,
            PageNumber = newPageNumber,
            ColumnCount = currentPageLayout?.ColumnCount ?? 2,
            LayoutElements = new List<LayoutElement>(),
            LayoutSettings = "{}",
            TemplateId = 1 // ЯВНО УСТАНАВЛИВАЕМ TemplateId = 1
        };

        AdjustColumnsLayout(newPageLayout);
        await LayoutService.CreateOrUpdatePageLayoutAsync(newPageLayout);
        await LoadData();
        currentPageNumber = newPageNumber;
        await LoadCurrentPageLayout();
        ShowNotification($"Страница {newPageNumber} добавлена.");
    }

    private async Task HandleRemovePage(PageLayout pageLayout)
    {
        foreach (var element in pageLayout.LayoutElements.ToList())
        {
            await LayoutService.RemoveElementFromLayoutAsync(element.LayoutElementId);
        }
    
        await LayoutService.DeletePageLayoutAsync(pageLayout.PageLayoutId);
    
        await LoadData();
    
        if (currentPageNumber > pageLayouts.Count)
        {
            currentPageNumber = pageLayouts.Count;
        }
    
        await LoadCurrentPageLayout();
        ShowNotification($"Страница {pageLayout.PageNumber} удалена.");
    }

    private async Task HandleClearAllPages()
    {
        try
        {
            var allLayouts = await LayoutService.GetPageLayoutsForIssueAsync(issueId);
        
            foreach (var pageLayout in allLayouts)
            {
                foreach (var element in pageLayout.LayoutElements.ToList())
                {
                    await LayoutService.RemoveElementFromLayoutAsync(element.LayoutElementId);
                }
            }
        
            foreach (var pageLayout in allLayouts)
            {
                await LayoutService.DeletePageLayoutAsync(pageLayout.PageLayoutId);
            }
        
            pageLayouts.Clear();
            currentPageLayout = null;
            currentPageNumber = 1;
        
            StateHasChanged();
            ShowNotification("Все страницы и их содержимое удалены.");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка при очистке страниц: {ex.Message}");
            ShowNotification($"Ошибка при очистке страниц: {ex.Message}");
        }
    }

    private async Task HandleRemoveArticleFromPage(PageLayout pageLayout, LayoutElement element)
    {
        await LayoutService.RemoveElementFromLayoutAsync(element.LayoutElementId);
        await LoadData();
        ShowNotification("Статья удалена со страницы.");
    }

    private async Task HandleSaveLayout()
    {
        if (pageLayouts.Any())
        {
            await LayoutService.UpdateIssueStatusAsync(issueId, IssueStatus.ReadyForPublish);
            ShowNotification("Макет сохранен. Статус выпуска изменен на 'Готов к публикации'.");
        }
        else
        {
            ShowNotification("Нет страниц для сохранения. Добавьте хотя бы одну страницу.");
        }
    }

    private void NavigateToTextStyle()
    {
        Navigation.NavigateTo($"/issues/{issueId}/text-style");
    }

    private void NavigateToHeaderFooter()
    {
        Navigation.NavigateTo($"/issues/{issueId}/header-footer");
    }

    private string GetArticlePreview(string content)
    {
        if (string.IsNullOrEmpty(content)) return "";
        return content.Length > 100 ? content.Substring(0, 100) + "..." : content;
    }

    private int GetWordCount(string content)
    {
        if (string.IsNullOrWhiteSpace(content)) return 0;
        return content.Split(new char[] { ' ', '\n', '\r', '\t' }, StringSplitOptions.RemoveEmptyEntries).Length;
    }

    private string GetArticleCardClass(ArticleStatus status)
    {
        return status switch
        {
            ArticleStatus.Approved => "border-start border-success border-5",
            ArticleStatus.UnderReview => "border-start border-info border-5",
            ArticleStatus.RequiresRevision => "border-start border-warning border-5",
            ArticleStatus.Draft => "border-start border-secondary border-5",
            ArticleStatus.Rejected => "border-start border-danger border-5",
            _ => ""
        };
    }

    private string GetStatusBadgeClass(ArticleStatus status)
    {
        return status switch
        {
            ArticleStatus.Approved => "bg-success",
            ArticleStatus.UnderReview => "bg-info",
            ArticleStatus.RequiresRevision => "bg-warning",
            ArticleStatus.Draft => "bg-secondary",
            ArticleStatus.Rejected => "bg-danger",
            _ => "bg-secondary"
        };
    }

    private string GetStatusBadgeClass(IssueStatus status)
    {
        return status switch
        {
            IssueStatus.InProgress => "bg-secondary",
            IssueStatus.LayoutInProgress => "bg-info",
            IssueStatus.ReadyForPublish => "bg-warning",
            IssueStatus.Published => "bg-success",
            _ => "bg-secondary"
        };
    }

    // Новый метод: Публиковать выпуск на главной странице
    private async Task PublishToHomepage()
    {
        try
        {
            // Проверяем, готов ли выпуск к публикации
            if (currentIssue?.Status != IssueStatus.ReadyForPublish && currentIssue?.Status != IssueStatus.Published)
            {
                ShowNotification("Выпуск должен быть готов к публикации (статус 'Готов к публикации')");
                return;
            }

            // Если выпуск еще не опубликован, меняем статус
            if (currentIssue?.Status != IssueStatus.Published)
            {
                await LayoutService.UpdateIssueStatusAsync(issueId, IssueStatus.Published);
            }

            // Делаем выпуск избранным (на главной странице)
            var result = await IssueService.SetAsFeaturedIssueAsync(issueId);
            
            if (result)
            {
                await LoadData();
                ShowNotification("Выпуск успешно опубликован на главной странице!");
            }
            else
            {
                ShowNotification("Не удалось опубликовать выпуск на главной странице.");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка при публикации выпуска: {ex.Message}");
            ShowNotification($"Ошибка при публикации: {ex.Message}");
        }
    }

    // Новый метод: Убрать выпуск с главной страницы
    private async Task RemoveFromHomepage()
    {
        try
        {
            if (currentIssue?.IsFeatured != true)
            {
                ShowNotification("Этот выпуск и так не находится на главной странице");
                return;
            }

            // Снимаем флаг избранного
            await IssueService.RemoveFromFeaturedAsync(issueId);
            await LoadData();
            ShowNotification("Выпуск убран с главной страницы.");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка при удалении с главной: {ex.Message}");
            ShowNotification($"Ошибка: {ex.Message}");
        }
    }
}

