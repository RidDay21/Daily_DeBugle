@using DailyDeBugle.Models
@using System.Text.Json
@using DailyDeBugle.Services

@page "/issues/{issueId:int}/layout"
@rendermode InteractiveServer
@inject DailyDeBugle.Services.IIssueService IssueService
@inject DailyDeBugle.Services.IArticleService ArticleService
@inject DailyDeBugle.Services.ILayoutService LayoutService
@inject NavigationManager Navigation

<h3>Layout for Issue: @issueId</h3>

<!-- Отладочная информация -->
<div class="alert alert-warning">
    <strong>Debug Info:</strong><br>
    Pages Count: @pageLayouts.Count<br>
    Last Action: @lastAction<br>
    Current Template: @selectedTemplate<br>
    Component Rendered: @DateTime.Now.ToString("HH:mm:ss.fff")
</div>

<div class="header-buttons mb-3">
    <button class="btn btn-success" @onclick="HandleAddPage">Add Page</button>
    
    <select @bind="selectedTemplate" class="form-select d-inline-block w-auto">
        <option value="Default Template">Default Template</option>
        <option value="Two Column Layout">Two Column Layout</option>
        <option value="With Sidebar">With Sidebar</option>
        <option value="Magazine Style">Magazine Style</option>
    </select>
    
    <a class="btn btn-info" href="/issues/@issueId/ads">Manage Ads</a>
    
    <button class="btn btn-primary" @onclick="HandleSaveLayout">Save Layout</button>
    <a class="btn btn-secondary" href="/issues">Back to Issues</a>
</div>

<div class="form-check mb-3">
    <input type="checkbox" class="form-check-input" @bind="showOnlyApproved" />
    <label class="form-check-label">Show only approved articles</label>
</div>

<hr />

<div class="section mb-4">
    <h4>Articles for Issue: @currentIssue?.IssueNumber</h4>
    
    @if (!filteredArticles.Any())
    {
        <p>No articles available for this issue.</p>
    }
    else
    {
        <div class="articles-list">
            @foreach (var article in filteredArticles)
            {
                <div class="article-item card mb-2 @GetArticleCardClass(article.Status)">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <h5 class="card-title">@article.Headline</h5>
                            <span class="badge @GetStatusBadgeClass(article.Status)">@article.Status</span>
                        </div>
                        <p class="card-text">@GetArticlePreview(article.Content)</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <small class="text-muted">
                                Author: @article.Author?.Username | 
                                Created: @article.CreatedDate.ToShortDateString() |
                                Words: @GetWordCount(article.Content)
                            </small>
                            <button class="btn btn-sm btn-outline-primary" @onclick="@(() => HandlePlaceArticle(article))">
                                Place on Page
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<div class="section">
    <h4>Current Pages Layout</h4>
    
    @if (pageLayouts.Any())
    {
        <div class="mb-3">
            <button class="btn btn-sm btn-outline-secondary" @onclick="HandleClearAllPages">Clear All Pages</button>
        </div>
        
        @foreach (var pageLayout in pageLayouts)
        {
            <div class="page-item card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Page @pageLayout.PageNumber (@selectedTemplate)</span>
                    <button class="btn btn-sm btn-outline-danger" @onclick="@(() => HandleRemovePage(pageLayout))">
                        Remove Page
                    </button>
                </div>
                <div class="card-body">
                    @if (pageLayout.LayoutElements.Any(le => le.Article != null))
                    {
                        <h6>Articles on this page:</h6>
                        <ul class="list-group">
                            @foreach (var element in pageLayout.LayoutElements.Where(le => le.Article != null))
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>@element.Article.Headline</strong>
                                        <span class="badge @GetStatusBadgeClass(element.Article.Status) ms-2">@element.Article.Status</span>
                                        <br>
                                        <small class="text-muted">by @element.Article.Author?.Username</small>
                                        <br>
                                        <small class="text-muted">Position: @element.Position | Size: @element.Size</small>
                                    </div>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="@(() => HandleRemoveArticleFromPage(pageLayout, element))">
                                        Remove
                                    </button>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted">No articles placed on this page yet.</p>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <p>No pages added yet. Click "Add Page" to start designing the layout.</p>
    }
</div>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-info mt-3">@message</div>
}

@code {
    [Parameter]
    public int issueId { get; set; }

    private Issue? currentIssue;
    private List<Article> allArticles = new List<Article>();
    private List<Article> filteredArticles = new List<Article>();
    private List<PageLayout> pageLayouts = new List<PageLayout>();
    private string selectedTemplate = "Default Template";
    private string message = "";
    private bool showOnlyApproved = false;
    private string lastAction = "None";

    protected override async Task OnInitializedAsync()
    {
        Console.WriteLine($"=== LAYOUT COMPONENT INITIALIZED for issue {issueId} ===");
        lastAction = "Component initialized";
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            currentIssue = await IssueService.GetIssueAsync(issueId);
            
            if (currentIssue != null)
            {
                allArticles = await ArticleService.GetArticlesByIssueAsync(issueId);
                pageLayouts = await LayoutService.GetPageLayoutsForIssueAsync(issueId);
                UpdateFilteredArticles();
                Console.WriteLine($"Loaded {allArticles.Count} articles and {pageLayouts.Count} page layouts for issue {issueId}");
                
                // Отладочная информация о загруженных страницах
                foreach (var page in pageLayouts)
                {
                    Console.WriteLine($"Page {page.PageNumber} has {page.LayoutElements.Count} elements");
                    foreach (var element in page.LayoutElements)
                    {
                        Console.WriteLine($"  - Element: ArticleId={element.ArticleId}, Type={element.Type}");
                    }
                }
            }
        }
        catch (Exception ex)
        {
            message = $"Error loading data: {ex.Message}";
            Console.WriteLine($"ERROR: {ex.Message}");
        }
    }

    private void UpdateFilteredArticles()
    {
        if (showOnlyApproved)
        {
            filteredArticles = allArticles.Where(a => a.Status == ArticleStatus.Approved).ToList();
        }
        else
        {
            filteredArticles = allArticles.ToList();
        }
        StateHasChanged();
    }

    // ОБРАБОТЧИКИ КНОПОК
    private async Task HandleAddPage()
    {
        Console.WriteLine("=== ADD PAGE BUTTON CLICKED ===");
        
        try
        {
            var newPageNumber = pageLayouts.Count + 1;

            // ВРЕМЕННОЕ РЕШЕНИЕ: создаем PageLayout без TemplateId
            // Для этого нам нужно обойти ограничение базы данных
            var newPageLayout = new PageLayout
            {
                IssueId = issueId,
                PageNumber = newPageNumber,
                LayoutElements = new List<LayoutElement>(),
                LayoutSettings = "{}"
            };

            // Используем рефлексию чтобы установить TemplateId = 1 (первый шаблон)
            // Это временное решение пока не создадим шаблоны в базе
            var templateIdProperty = typeof(PageLayout).GetProperty("TemplateId");
            if (templateIdProperty != null && templateIdProperty.CanWrite)
            {
                templateIdProperty.SetValue(newPageLayout, 1);
            }

            // Сохраняем в базу
            await LayoutService.CreateOrUpdatePageLayoutAsync(newPageLayout);
            
            // Перезагружаем данные
            pageLayouts = await LayoutService.GetPageLayoutsForIssueAsync(issueId);
            
            message = $"Page {newPageNumber} added successfully!";
            lastAction = $"Added page {newPageNumber} at {DateTime.Now:HH:mm:ss}";
            
            Console.WriteLine($"Page {newPageNumber} added. Total pages: {pageLayouts.Count}");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            message = $"Error adding page: {ex.Message}";
            lastAction = "Add page failed";
            Console.WriteLine($"ERROR adding page: {ex.Message}");
            StateHasChanged();
        }
    }

    private async Task HandleRemovePage(PageLayout pageLayout)
    {
        try
        {
            // Удаляем все элементы макета для этой страницы
            foreach (var element in pageLayout.LayoutElements.ToList())
            {
                await LayoutService.RemoveElementFromLayoutAsync(element.LayoutElementId);
            }
            
            // Перезагружаем данные
            pageLayouts = await LayoutService.GetPageLayoutsForIssueAsync(issueId);
            
            message = $"Page {pageLayout.PageNumber} removed.";
            lastAction = $"Removed page {pageLayout.PageNumber}";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            message = $"Error removing page: {ex.Message}";
            lastAction = "Remove page failed";
            Console.WriteLine($"ERROR removing page: {ex.Message}");
            StateHasChanged();
        }
    }

    private async Task HandleClearAllPages()
    {
        try
        {
            // Удаляем все страницы
            foreach (var pageLayout in pageLayouts.ToList())
            {
                foreach (var element in pageLayout.LayoutElements.ToList())
                {
                    await LayoutService.RemoveElementFromLayoutAsync(element.LayoutElementId);
                }
            }
            
            pageLayouts = new List<PageLayout>();
            message = "All pages cleared.";
            lastAction = "Cleared all pages";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            message = $"Error clearing pages: {ex.Message}";
            lastAction = "Clear pages failed";
            Console.WriteLine($"ERROR clearing pages: {ex.Message}");
            StateHasChanged();
        }
    }

    private async Task HandlePlaceArticle(Article article)
    {
        try
        {
            if (!pageLayouts.Any())
            {
                message = "Please add at least one page before placing articles.";
                lastAction = "No pages available";
                StateHasChanged();
                return;
            }
            
            // Проверяем, не размещена ли статья уже на какой-то странице
            var existingElement = pageLayouts
                .SelectMany(pl => pl.LayoutElements)
                .FirstOrDefault(le => le.ArticleId == article.ArticleId);
                
            if (existingElement != null)
            {
                message = $"Article '{article.Headline}' is already placed on a page.";
                lastAction = "Article already placed";
                StateHasChanged();
                return;
            }
            
            // Берем первую страницу
            var firstPage = pageLayouts.First();
            
            // Добавляем статью на страницу через сервис
            var defaultPosition = JsonSerializer.Serialize(new { X = 0, Y = 0 });
            var defaultSize = JsonSerializer.Serialize(new { Width = 100, Height = 100 });
            
            await LayoutService.AddArticleToLayoutAsync(
                firstPage.PageLayoutId, 
                article.ArticleId, 
                defaultPosition, 
                defaultSize
            );
            
            // Перезагружаем данные
            pageLayouts = await LayoutService.GetPageLayoutsForIssueAsync(issueId);
            
            message = $"Article '{article.Headline}' placed on page 1.";
            lastAction = $"Placed article: {article.Headline}";
            
            Console.WriteLine($"Article {article.ArticleId} placed on page {firstPage.PageNumber}");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            message = $"Error placing article: {ex.Message}";
            lastAction = "Place article failed";
            Console.WriteLine($"ERROR placing article: {ex.Message}");
            StateHasChanged();
        }
    }

    private async Task HandleRemoveArticleFromPage(PageLayout pageLayout, LayoutElement element)
    {
        try
        {
            await LayoutService.RemoveElementFromLayoutAsync(element.LayoutElementId);
            
            // Перезагружаем данные
            pageLayouts = await LayoutService.GetPageLayoutsForIssueAsync(issueId);
            
            message = $"Article '{element.Article.Headline}' removed from page {pageLayout.PageNumber}.";
            lastAction = $"Removed article from page {pageLayout.PageNumber}";
            
            Console.WriteLine($"Article {element.ArticleId} removed from page {pageLayout.PageNumber}");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            message = $"Error removing article: {ex.Message}";
            lastAction = "Remove article failed";
            Console.WriteLine($"ERROR removing article: {ex.Message}");
            StateHasChanged();
        }
    }

    private async Task HandleSaveLayout()
    {
        try
        {
            if (!pageLayouts.Any())
            {
                message = "Error: Cannot save layout without pages. Please add at least one page.";
                lastAction = "Save failed: no pages";
                StateHasChanged();
                return;
            }
            
            // Обновляем статус выпуска на "Ready for Print"
            await LayoutService.UpdateIssueStatusAsync(issueId, IssueStatus.ReadyForPublish);
            
            var totalArticles = pageLayouts.Sum(pl => pl.LayoutElements.Count(le => le.Article != null));
            message = $"Layout saved successfully with {pageLayouts.Count} pages and {totalArticles} articles! Status updated to Ready for Print.";
            lastAction = $"Saved layout with {pageLayouts.Count} pages";
            
            Console.WriteLine($"Layout saved for issue {issueId} with {pageLayouts.Count} pages and {totalArticles} articles");
            
            // Показываем детальную информацию о сохраненном макете
            foreach (var page in pageLayouts)
            {
                Console.WriteLine($"Page {page.PageNumber}: {page.LayoutElements.Count} elements");
            }
        }
        catch (Exception ex)
        {
            message = $"Error saving layout: {ex.Message}";
            lastAction = "Save failed";
            Console.WriteLine($"ERROR saving layout: {ex.Message}");
        }
        
        StateHasChanged();
    }

    // Вспомогательные методы
    private string GetArticlePreview(string content)
    {
        if (string.IsNullOrEmpty(content)) return "";
        return content.Length > 100 ? content.Substring(0, 100) + "..." : content;
    }

    private int GetWordCount(string content)
    {
        if (string.IsNullOrWhiteSpace(content)) return 0;
        return content.Split(new char[] { ' ', '\n', '\r', '\t' }, StringSplitOptions.RemoveEmptyEntries).Length;
    }

    private string GetArticleCardClass(ArticleStatus status)
    {
        return status switch
        {
            ArticleStatus.Approved => "border-success",
            ArticleStatus.UnderReview => "border-info",
            ArticleStatus.RequiresRevision => "border-warning",
            ArticleStatus.Draft => "border-secondary",
            ArticleStatus.Rejected => "border-danger",
            _ => ""
        };
    }

    private string GetStatusBadgeClass(ArticleStatus status)
    {
        return status switch
        {
            ArticleStatus.Approved => "bg-success",
            ArticleStatus.UnderReview => "bg-info",
            ArticleStatus.RequiresRevision => "bg-warning",
            ArticleStatus.Draft => "bg-secondary",
            ArticleStatus.Rejected => "bg-danger",
            _ => "bg-secondary"
        };
    }
}