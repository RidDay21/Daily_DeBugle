    private void ValidateLayout()
    {
        layoutErrors.Clear();
    
        if (currentPageLayout == null) return;
    
        // Проверяем, что все влезает на страницу
        double totalWidth = currentPageLayout.MarginLeft + currentPageLayout.TextAreaWidth + currentPageLayout.MarginRight;
        if (totalWidth > PAGE_WIDTH)
        {
            layoutErrors.Add($"Суммарная ширина ({totalWidth:F1} см) превышает ширину страницы ({PAGE_WIDTH} см)");
        }
    
        double totalHeight = currentPageLayout.MarginTop + currentPageLayout.TextAreaHeight + currentPageLayout.MarginBottom;
        if (totalHeight > PAGE_HEIGHT)
        {
            layoutErrors.Add($"Суммарная высота ({totalHeight:F1} см) превышает высоту страницы ({PAGE_HEIGHT} см)");
        }
    
        // Проверяем ширину колонок (не менее 4 см для читаемости)
        double columnWidth = GetColumnWidth();
        if (columnWidth < MIN_COLUMN_WIDTH)
        {
            layoutErrors.Add($"Ширина колонки ({columnWidth:F1} см) слишком мала (минимум {MIN_COLUMN_WIDTH} см)");
        }
    }

