            ArticleStatus.UnderReview => "bg-info",
            ArticleStatus.RequiresRevision => "bg-warning",
            ArticleStatus.Draft => "bg-secondary",
            ArticleStatus.Rejected => "bg-danger",
            _ => "bg-secondary"
        };
    }

    // Методы для работы с элементами (оставлены для внутренней логики)
    private List<LayoutElement> GetElementsInColumn(PageLayout layout, int columnIndex)
    {
        var elements = new List<LayoutElement>();
    
        if (layout == null || layout.ColumnCount == 0) return elements;
    
        double columnWidth = GetColumnWidth();
        double columnSpacing = columnWidth + layout.ColumnGap;
    
        foreach (var element in layout.LayoutElements)
        {
            var position = GetElementPosition(element);
        
            // Определяем колонку с учетом промежутков
            int elementColumn = (int)(position.X / columnSpacing);
        
            if (elementColumn == columnIndex)
            {
                elements.Add(element);
            }
        }
    
        return elements.OrderBy(e => GetElementPosition(e).Y).ToList();
    }

    private (double X, double Y) GetElementPosition(LayoutElement element)
    {
        // Простая реализация - возвращаем позицию из JSON или (0,0)
        try
        {
            if (!string.IsNullOrEmpty(element.Position))
            {
                var position = JsonSerializer.Deserialize<Dictionary<string, double>>(element.Position);
                if (position != null)
                {
                    double x = position.ContainsKey("X") ? position["X"] : 0;
                    double y = position.ContainsKey("Y") ? position["Y"] : 0;
                    return (x, y);
                }
            }
        }
        catch
        {
            // Игнорируем ошибки парсинга
        }
    
        return (0, 0);
    }

    private (double Width, double Height) GetElementSize(LayoutElement element)
    {
        try
        {
            if (!string.IsNullOrEmpty(element.Size))
            {
                var size = JsonSerializer.Deserialize<Dictionary<string, double>>(element.Size);
                if (size != null && size.ContainsKey("Width") && size.ContainsKey("Height"))
                {
                    return (size["Width"], size["Height"]);
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка парсинга размера: {ex.Message}");
        }
    
        // Размеры по умолчанию: 1 колонка шириной, высота 3 см
        double columnWidth = currentPageLayout?.TextAreaWidth / currentPageLayout?.ColumnCount ?? 5.0;
        return (columnWidth, 3.0);
    }
