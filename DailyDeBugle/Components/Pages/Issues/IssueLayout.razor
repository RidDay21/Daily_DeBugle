    }
    
    // Проверяет все страницы на переполнение и создает новые при необходимости
private async Task CheckAndFixOverflow()
{
    bool changesMade = false;
    
    foreach (var pageLayout in pageLayouts.OrderBy(p => p.PageNumber).ToList())
    {
        var elementsInColumn = GetElementsInColumn(pageLayout, 0);
        double totalHeight = 0.5; // Начальный отступ
        
        foreach (var element in elementsInColumn)
        {
            var size = GetElementSize(element);
            totalHeight += size.Height + 0.5; // Высота элемента + отступ
            
            // Если суммарная высота превышает допустимую
            if (totalHeight > pageLayout.TextAreaHeight)
            {
                // Находим все элементы после текущего
                var elementsToMove = elementsInColumn
                    .SkipWhile(e => e != element)
                    .ToList();
                
                // Создаем новую страницу
                var newPageNumber = pageLayouts.Count + 1;
                var newPageLayout = new PageLayout
                {
                    IssueId = issueId,
                    PageNumber = newPageNumber,
                    ColumnCount = pageLayout.ColumnCount,
                    LayoutElements = new List<LayoutElement>(),
                    LayoutSettings = "{}",
                    TemplateId = pageLayout.TemplateId
                };
                
                await LayoutService.CreateOrUpdatePageLayoutAsync(newPageLayout);
                changesMade = true;
                
                // Переносим элементы на новую страницу
                double newPageY = 0.5;
                foreach (var elementToMove in elementsToMove)
                {
                    // Удаляем элемент со старой страницы
                    await LayoutService.RemoveElementFromLayoutAsync(elementToMove.LayoutElementId);
                    
                    // Добавляем на новую страницу
                    if (elementToMove.ArticleId.HasValue)
                    {
                        var position = JsonSerializer.Serialize(new { X = 0, Y = newPageY });
                        var elementSize = GetElementSize(elementToMove);
                        var sizeJson = JsonSerializer.Serialize(new { 
                            Width = elementSize.Width, 
                            Height = elementSize.Height 
                        });
                        
                        await LayoutService.AddArticleToLayoutAsync(
                            newPageLayout.PageLayoutId,
                            elementToMove.ArticleId.Value,
                            position,
                            sizeJson
                        );
                    }
                    
                    newPageY += GetElementSize(elementToMove).Height + 0.5;
                }
                
                break; // Прерываем после первого переполнения
            }
        }
    }
    
    if (changesMade)
    {
        await LoadData();
        ShowNotification("Обнаружено переполнение страниц. Часть статей была автоматически перенесена на новые страницы.");
    }
}

    private async Task SaveLayoutConfig()
    {
        if (currentPageLayout != null)
        {
            currentPageLayout.TemplateId = selectedTemplateId ?? 0;
            await LayoutService.CreateOrUpdatePageLayoutAsync(currentPageLayout);
