    private async Task HandleRemovePage(PageLayout pageLayout)
    {
        foreach (var element in pageLayout.LayoutElements.ToList())
        {
            await LayoutService.RemoveElementFromLayoutAsync(element.LayoutElementId);
        }
    
        await LayoutService.DeletePageLayoutAsync(pageLayout.PageLayoutId);
    
        await LoadData();
    
        if (currentPageNumber > pageLayouts.Count)
        {
            currentPageNumber = pageLayouts.Count;
        }
    
        await LoadCurrentPageLayout();
    }

    private async Task HandleClearAllPages()
    {
        try
        {
            // Получаем все макеты страниц для этого выпуска
            var allLayouts = await LayoutService.GetPageLayoutsForIssueAsync(issueId);
        
            // Удаляем все элементы макета
            foreach (var pageLayout in allLayouts)
            {
                foreach (var element in pageLayout.LayoutElements.ToList())
                {
                    await LayoutService.RemoveElementFromLayoutAsync(element.LayoutElementId);
                }
            }
        
            // Удаляем сами макеты страниц
            foreach (var pageLayout in allLayouts)
            {
                await LayoutService.DeletePageLayoutAsync(pageLayout.PageLayoutId);
            }
        
            // Очищаем локальные списки
            pageLayouts.Clear();
            currentPageLayout = null;
            currentPageNumber = 1;
        
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка при очистке страниц: {ex.Message}");
        }
    }

    private async Task HandlePlaceArticle(Article article)
{
    if (currentPageLayout != null)
    {
        double columnWidth = GetColumnWidth();
        double columnSpacing = columnWidth + currentPageLayout.ColumnGap;
        
        // Автоматически выбираем первую колонку
        int selectedColumn = 0;
        double x = selectedColumn * columnSpacing;
        
        // Определяем Y-позицию (ставим после последнего элемента в колонке 0)
        var elementsInColumn = GetElementsInColumn(currentPageLayout, 0);
        double y = 0.5; // Отступ от верха
        
        if (elementsInColumn.Any())
        {
            // Берем последний элемент в первой колонке
            var lastElement = elementsInColumn.Last();
            var lastPosition = GetElementPosition(lastElement);
            var lastSize = GetElementSize(lastElement);
            y = lastPosition.Y + lastSize.Height + 0.5;
        }
        
        // Рассчитываем высоту статьи на основе количества символов
        double elementHeight = CalculateArticleHeight(article);
        
        // Проверяем, помещается ли статья на текущей странице
        bool needsNewPage = await CheckIfNeedsNewPage(currentPageLayout, elementHeight, y);
        
        PageLayout targetPageLayout = currentPageLayout;
        double targetY = y;
        int targetPageNumber = currentPageNumber;
        
        if (needsNewPage)
        {
            // Создаем новую страницу
            targetPageNumber = pageLayouts.Count + 1;
            var newPageLayout = new PageLayout
            {
                IssueId = issueId,
                PageNumber = targetPageNumber,
                ColumnCount = currentPageLayout.ColumnCount,
                LayoutElements = new List<LayoutElement>(),
                LayoutSettings = "{}",
                TemplateId = currentPageLayout.TemplateId,
                MarginTop = currentPageLayout.MarginTop,
                MarginBottom = currentPageLayout.MarginBottom,
                MarginLeft = currentPageLayout.MarginLeft,
                MarginRight = currentPageLayout.MarginRight,
                TextAreaWidth = currentPageLayout.TextAreaWidth,
                TextAreaHeight = currentPageLayout.TextAreaHeight,
                ColumnGap = currentPageLayout.ColumnGap
            };

            await LayoutService.CreateOrUpdatePageLayoutAsync(newPageLayout);
            await LoadData();
            
            targetPageLayout = pageLayouts.FirstOrDefault(p => p.PageNumber == targetPageNumber);
            targetY = 0.5; // Начинаем с верха новой страницы
            
            // Показываем уведомление
            ShowNotification($"Статья не поместилась на странице {currentPageNumber}. " +
                           $"Была создана страница {targetPageNumber}.");
            
            // Переключаемся на новую страницу
            await SwitchToPage(targetPageNumber);
        }
        else if (y + elementHeight > currentPageLayout.TextAreaHeight)
        {
            // Если не помещается по высоте, просто ставим сверху (для простоты)
            y = 0.5;
        }
        
        var position = JsonSerializer.Serialize(new { X = x, Y = targetY });
        var size = JsonSerializer.Serialize(new { Width = columnWidth, Height = elementHeight });
        
        await LayoutService.AddArticleToLayoutAsync(
            targetPageLayout.PageLayoutId, 
            article.ArticleId, 
            position, 
            size
        );
        
        await LoadData();
    }
}

// Проверяет, нужна ли новая страница для статьи
private async Task<bool> CheckIfNeedsNewPage(PageLayout layout, double articleHeight, double proposedY)
{
    // Если статья не помещается по высоте на текущей странице
    if (proposedY + articleHeight > layout.TextAreaHeight)
    {
        // Проверяем, есть ли еще страницы после текущей
        var nextPage = pageLayouts.FirstOrDefault(p => p.PageNumber == currentPageNumber + 1);
        
        if (nextPage != null)
        {
            // Проверяем, поместится ли статья на следующей странице
            var elementsOnNextPage = GetElementsInColumn(nextPage, 0);
            double nextPageY = 0.5;
            
            if (elementsOnNextPage.Any())
            {
                var lastElement = elementsOnNextPage.Last();
                var lastPosition = GetElementPosition(lastElement);
                var lastSize = GetElementSize(lastElement);
                nextPageY = lastPosition.Y + lastSize.Height + 0.5;
            }
            
            // Если на следующей странице есть место
            if (nextPageY + articleHeight <= nextPage.TextAreaHeight)
            {
                return false; // Не создаем новую, используем существующую
            }
        }
        
        return true; // Нужна новая страница
    }
    
    return false;
}

// Рассчитывает высоту статьи на основе количества символов
private double CalculateArticleHeight(Article article)
{
    if (article == null || string.IsNullOrEmpty(article.Content)) 
        return 3.0; // Минимальная высота
    
    // Базовые параметры (можно вынести в настройки)
    const double charsPerCm = 35.0; // Примерно 35 символов на 1 см высоты при 12pt шрифте
    const double lineHeightCm = 0.45; // Высота строки в см
    const double minHeight = 3.0; // Минимальная высота статьи
    const double maxHeight = 15.0; // Максимальная высота на одной странице
    
    // Рассчитываем примерное количество строк
    double estimatedLines = article.Content.Length / charsPerCm;
    double estimatedHeight = estimatedLines * lineHeightCm;
    
    // Добавляем высоту для заголовка и отступов
    estimatedHeight += 1.0;
    
    // Ограничиваем минимальной и максимальной высотой
    estimatedHeight = Math.Max(minHeight, Math.Min(estimatedHeight, maxHeight));
    
    return Math.Round(estimatedHeight, 1);
}

// Методы для уведомлений
private string? notificationMessage = null;

private void ShowNotification(string message)
{
    notificationMessage = message;
    StateHasChanged();
    
    // Автоматически скрыть уведомление через 5 секунд
    _ = AutoDismissNotification();
}

private async Task AutoDismissNotification()
{
    await Task.Delay(5000);
    notificationMessage = null;
    await InvokeAsync(StateHasChanged);
}

private void DismissNotification()
{
    notificationMessage = null;
    StateHasChanged();
}

