    // Новый метод: Публиковать выпуск на главной странице
    private async Task PublishToHomepage()
    {
        try
        {
            // Проверяем, готов ли выпуск к публикации
            if (currentIssue?.Status != IssueStatus.ReadyForPublish && currentIssue?.Status != IssueStatus.Published)
            {
                ShowNotification("Выпуск должен быть готов к публикации (статус 'Готов к публикации')");
                return;
            }

            // Если выпуск еще не опубликован, меняем статус
            if (currentIssue?.Status != IssueStatus.Published)
            {
                await LayoutService.UpdateIssueStatusAsync(issueId, IssueStatus.Published);
            }

            // Делаем выпуск избранным (на главной странице)
            var result = await IssueService.SetAsFeaturedIssueAsync(issueId);
            
            if (result)
            {
                await LoadData();
                ShowNotification("Выпуск успешно опубликован на главной странице!");
            }
            else
            {
                ShowNotification("Не удалось опубликовать выпуск на главной странице.");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка при публикации выпуска: {ex.Message}");
            ShowNotification($"Ошибка при публикации: {ex.Message}");
        }
    }

    // Новый метод: Убрать выпуск с главной страницы
    private async Task RemoveFromHomepage()
    {
        try
        {
            if (currentIssue?.IsFeatured != true)
            {
                ShowNotification("Этот выпуск и так не находится на главной странице");
                return;
            }

            // Снимаем флаг избранного
            await IssueService.RemoveFromFeaturedAsync(issueId);
            await LoadData();
            ShowNotification("Выпуск убран с главной страницы.");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка при удалении с главной: {ex.Message}");
            ShowNotification($"Ошибка: {ex.Message}");
        }
    }
