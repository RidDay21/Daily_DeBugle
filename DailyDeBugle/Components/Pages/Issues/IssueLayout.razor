        Navigation.NavigateTo($"/issues/{issueId}/header-footer");
    }

    private string GetArticlePreview(string content)
    {
        if (string.IsNullOrEmpty(content)) return "";
        return content.Length > 100 ? content.Substring(0, 100) + "..." : content;
    }

    private int GetWordCount(string content)
    {
        if (string.IsNullOrWhiteSpace(content)) return 0;
        return content.Split(new char[] { ' ', '\n', '\r', '\t' }, StringSplitOptions.RemoveEmptyEntries).Length;
    }

    private string GetArticleCardClass(ArticleStatus status)
    {
        return status switch
        {
            ArticleStatus.Approved => "border-start border-success border-5",
            ArticleStatus.UnderReview => "border-start border-info border-5",
            ArticleStatus.RequiresRevision => "border-start border-warning border-5",
            ArticleStatus.Draft => "border-start border-secondary border-5",
            ArticleStatus.Rejected => "border-start border-danger border-5",
            _ => ""
        };
    }

    private string GetStatusBadgeClass(ArticleStatus status)
    {
        return status switch
        {
            ArticleStatus.Approved => "bg-success",
            ArticleStatus.UnderReview => "bg-info",
            ArticleStatus.RequiresRevision => "bg-warning",
            ArticleStatus.Draft => "bg-secondary",
            ArticleStatus.Rejected => "bg-danger",
            _ => "bg-secondary"
        };
    }

    private string GetStatusBadgeClass(IssueStatus status)
    {
        return status switch
        {
            IssueStatus.InProgress => "bg-secondary",
            IssueStatus.LayoutInProgress => "bg-info",
            IssueStatus.ReadyForPublish => "bg-warning",
            IssueStatus.Published => "bg-success",
            _ => "bg-secondary"
        };
    }

    private async Task PublishToHomepage()
    {
        try
        {
            if (currentIssue?.Status != IssueStatus.ReadyForPublish && currentIssue?.Status != IssueStatus.Published)
            {
                ShowNotification("Issue must be ready for publication (status 'Ready for Publication')");
                return;
            }

            if (currentIssue?.Status != IssueStatus.Published)
            {
                await LayoutService.UpdateIssueStatusAsync(issueId, IssueStatus.Published);
            }

            var result = await IssueService.SetAsFeaturedIssueAsync(issueId);
            
            if (result)
            {
                await LoadData();
                ShowNotification("Issue successfully published on the home page!");
            }
            else
            {
                ShowNotification("Failed to publish issue on the home page.");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error publishing issue: {ex.Message}");
            ShowNotification($"Error publishing: {ex.Message}");
        }
    }

    private async Task RemoveFromHomepage()
    {
        try
        {
            if (currentIssue?.IsFeatured != true)
            {
                ShowNotification("This issue is not on the home page anyway");
                return;
            }

            await IssueService.RemoveFromFeaturedAsync(issueId);
            await LoadData();
            ShowNotification("Issue removed from the home page.");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error removing from home page: {ex.Message}");
            ShowNotification($"Error: {ex.Message}");
        }
    }
}

