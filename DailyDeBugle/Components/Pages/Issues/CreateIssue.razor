@page "/issues/create"
@attribute [Authorize(Policy = Policies.ManageIssues)]
@rendermode InteractiveServer
@inject IIssueService IssueService
@inject NavigationManager Nav
@using DailyDeBugle.Models
@using DailyDeBugle.Services

<h3>Create New Issue</h3>

@if (publications == null)
{
    <p>Loading publications...</p>
}
else
{
    <EditForm Model="@newIssue" OnValidSubmit="HandleValidSubmit" FormName="CreateIssueForm">
    	<DataAnnotationsValidator />
    	<ValidationSummary />

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        <div class="mb-3">
            <label>Publication:</label>
            <InputSelect @bind-Value="newIssue.PublicationId" class="form-select">
                <option value="@(default(int))">Select publication</option>
                @foreach (var pub in publications)
                {
                    <option value="@pub.PublicationId">@pub.Name</option>
                }
            </InputSelect>
            <ValidationMessage For="@(() => newIssue.PublicationId)" />
        </div>

        <div class="mb-3">
            <label>Issue Number:</label>
            <InputText @bind-Value="newIssue.IssueNumber" class="form-control" />
            <ValidationMessage For="@(() => newIssue.IssueNumber)" />
        </div>

        <div class="mb-3">
            <label>Issue Date:</label>
            <InputDate @bind-Value="newIssue.IssueDate" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Cover Image:</label>
            <InputFile OnChange="HandleFileSelected" 
                      accept=".jpg,.jpeg,.png,.gif" />
            <small class="form-text text-muted">
                Formats: JPG, PNG, GIF • Max size: 10 MB
            </small>
            @if (coverFile != null)
            {
                <div class="mt-2">
                    <small>Selected: @coverFile.Name (@(coverFile.Size / 1024) KB)</small>
                </div>
            }
        </div>

        <button class="btn btn-primary" type="submit" disabled="@isSubmitting">
            @(isSubmitting ? "Creating..." : "Create")
        </button>
        <a href="/issues" class="btn btn-secondary">Cancel</a>
    </EditForm>
}

@code {
    private Issue newIssue = new() { IssueDate = DateTime.Today };
    private List<Publication>? publications;
    private string? errorMessage;
    private bool isSubmitting = false;
    private IBrowserFile? coverFile;

    protected override async Task OnInitializedAsync()
    {
        publications = await IssueService.GetPublicationsAsync();
    }

    private async Task HandleValidSubmit()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            // Если был выбран файл, загружаем его
            if (coverFile != null)
            {
                newIssue.CoverImagePath = await UploadCoverImage(coverFile);
            }

            await IssueService.CreateAsync(newIssue);
            Nav.NavigateTo("/issues");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error creating issue: {ex.Message}";
            isSubmitting = false;
        }
        try
        {
            // ДОБАВЬТЕ ЭТИ СТРОКИ ДЛЯ ОТЛАДКИ
            Console.WriteLine($"=== DEBUG ===");
            Console.WriteLine($"PublicationId: {newIssue.PublicationId}");
            Console.WriteLine($"IssueNumber: {newIssue.IssueNumber}");
            Console.WriteLine($"IssueDate: {newIssue.IssueDate}");

            // Проверка что PublicationId не 0
            if (newIssue.PublicationId == 0)
            {
                Console.WriteLine("ERROR: PublicationId is 0 - no publication selected!");
                // Можно показать сообщение пользователю
                return;
            }

            await IssueService.CreateAsync(newIssue);
            Console.WriteLine("SUCCESS: Issue created!");
            Nav.NavigateTo("/issues");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"ERROR: {ex.Message}");
            Console.WriteLine($"StackTrace: {ex.StackTrace}");
            // Можно добавить отображение ошибки пользователю
        }
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        
        // Проверка размера файла (10 MB)
        if (file.Size > 10 * 1024 * 1024)
        {
            errorMessage = "File size exceeds 10 MB limit.";
            return;
        }

        // Проверка типа файла
        var allowedExtensions = new[] { ".jpg", ".jpeg", ".png", ".gif" };
        var extension = Path.GetExtension(file.Name).ToLower();
        
        if (!allowedExtensions.Contains(extension))
        {
            errorMessage = "Invalid file format. Please upload JPG, PNG or GIF.";
            return;
        }

        coverFile = file;
        errorMessage = null;
        StateHasChanged();
    }

    private async Task<string> UploadCoverImage(IBrowserFile file)
    {
        // Создаем директорию если не существует
        var uploadsDir = Path.Combine("wwwroot", "covers");
        if (!Directory.Exists(uploadsDir))
            Directory.CreateDirectory(uploadsDir);

        // Генерируем уникальное имя файла
        var extension = Path.GetExtension(file.Name);
        var uniqueFileName = $"{Guid.NewGuid()}{extension}";
        var filePath = Path.Combine(uploadsDir, uniqueFileName);

        // Сохраняем файл
        await using var fs = new FileStream(filePath, FileMode.Create);
        await file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(fs);

        return $"/covers/{uniqueFileName}";
    }
}
