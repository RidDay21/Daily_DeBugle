@page "/issues"
@attribute [Authorize(Policy = Policies.ViewContent)]
@rendermode InteractiveServer
@inject IIssueService IssueService
@inject NavigationManager NavigationManager
@using DailyDeBugle.Models
@using DailyDeBugle.Services

<h3>Issues</h3>

<AuthorizeView Policy="@Policies.ManageIssues">
    <a class="btn btn-success mb-3" href="/issues/create">+ New Issue</a>
</AuthorizeView>

@if (issues == null)
{
    <p>Loading...</p>
}
else if (issues.Count == 0)
{
    <p>No issues yet.</p>
}
else
{
    <table class="table table-striped">
        <thead>
        <tr>
            <th>Publication</th>
            <th>Number</th>
            <th>Date</th>
            <th>Status</th>
            <th>Cover</th>
            <th>Actions</th> <!-- ДОБАВЛЕН НОВЫЙ СТОЛБЕЦ -->
            @* <th style="width: 200px;">Actions</th> *@
        </tr>
        </thead>
        <tbody>
        @foreach (var issue in issues)
        {
            <tr>
                <td>@issue.Publication?.Name</td>
                <td>@issue.IssueNumber</td>
                <td>@issue.IssueDate.ToShortDateString()</td>
                <td>
                    <span class="badge @GetStatusBadgeClass(issue.Status)">
                        @issue.Status
                    </span>
                </td>
                <td>
                    @if (!string.IsNullOrEmpty(issue.CoverImagePath))
                    {
                        <img src="@issue.CoverImagePath" width="80" alt="Cover" class="img-thumbnail" />
                    }
                    else
                    {
                        <span class="text-muted">No cover</span>
                    }
                </td>
                <td>
                    <AuthorizeView Policy="@Policies.ManageIssues">
                        @if (issue.Status != IssueStatus.Published)
                        {
                            <a href="/issues/edit/@issue.IssueId"
                               class="btn btn-outline-primary btn-sm me-1"
                               title="Edit">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                        }

                        <button class="btn btn-outline-danger btn-sm"
                                @onclick="() => ShowDeleteConfirmation(issue)"
                                title="Delete">
                            <i class="bi bi-trash"></i> Delete
                        </button>
                    </AuthorizeView>

                    <AuthorizeView Policy="@Policies.LayoutIssue">
                        <a class="btn btn-primary btn-sm" href="/issues/@issue.IssueId/layout">
                            Layout
                        </a>
                    </AuthorizeView>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

@if (showDeleteDialog)
{
    <div class="modal fade show" style="display: block; background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        Confirm Delete
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseDeleteDialog"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete issue <strong>@issueToDelete?.IssueNumber</strong>?</p>
                    <p class="text-danger">
                        <small>
                            This will permanently delete all articles, layouts, and the cover image.
                            This action cannot be undone.
                        </small>
                    </p>
                </div>
                <div class="modal-footer">
                    <a class="btn btn-danger" href="/issues/delete/@issueToDelete?.IssueId">
                        <i class="bi bi-trash me-2"></i>
                        Yes, Delete Permanently
                    </a>
                    <button type="button" class="btn btn-secondary" @onclick="CloseDeleteDialog">
                        <i class="bi bi-x-circle me-2"></i>
                        Cancel
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Issue>? issues;
    private bool showDeleteDialog = false;
    private Issue? issueToDelete;

    protected override async Task OnInitializedAsync()
    {
        await LoadIssues();
    }

    private async Task LoadIssues()
    {
        issues = await IssueService.GetAllAsync();
    }

    private void ShowDeleteConfirmation(Issue issue)
    {
        issueToDelete = issue;
        showDeleteDialog = true;
    }

    private void CloseDeleteDialog()
    {
        showDeleteDialog = false;
        issueToDelete = null;
    }

    private string GetStatusBadgeClass(IssueStatus status)
    {
        return status switch
        {
            IssueStatus.InProgress => "bg-warning text-dark",
            IssueStatus.LayoutInProgress => "bg-info text-dark",
            IssueStatus.ReadyForPublish => "bg-success",
            IssueStatus.Published => "bg-primary",
            _ => "bg-secondary"
        };
    }
}