@page "/issues"
@attribute [Authorize(Policy = Policies.ViewContent)]
@rendermode InteractiveServer
@inject IIssueService IssueService
@inject NavigationManager NavigationManager
@using DailyDeBugle.Models
@using DailyDeBugle.Services
@using DailyDeBugle.Security

<PageTitle>Issues - Daily DeBugle</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Newspaper Issues</h2>
        <AuthorizeView Policy="@Policies.ManageIssues">
            <a href="/issues/create" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i> Create New Issue
            </a>
        </AuthorizeView>
    </div>

    @if (issues == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2">Loading issues...</p>
        </div>
    }
    else if (!issues.Any())
    {
        <div class="alert alert-info text-center py-4">
            <h4>No issues found</h4>
            <p>The newspaper doesn't have any issues yet.</p>
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Publication</th>
                        <th>Issue Date</th>
                        <th>Status</th>
                        <th>Articles</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var issue in issues.OrderByDescending(i => i.IssueDate))
                    {
                        <tr>
                            <td class="fw-bold">@issue.IssueNumber</td>
                            <td>@(issue.Publication?.Name ?? "General")</td>
                            <td>@issue.IssueDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                <span class="badge @GetStatusBadgeClass(issue.Status)">
                                    @issue.Status
                                </span>
                            </td>
                            <td>
                                <span class="badge bg-secondary rounded-pill">
                                    @(issue.Articles?.Count ?? 0)
                                </span>
                            </td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm">
                                    <a href="/issues/@issue.IssueId/read" class="btn btn-outline-primary" title="Read">
                                        <i class="bi bi-book"></i> Read
                                    </a>
                                    
                                    <AuthorizeView Policy="@Policies.LayoutIssue">
                                        <a href="/issues/@issue.IssueId/layout" class="btn btn-outline-info" title="Edit Layout">
                                            <i class="bi bi-layout-text-window"></i> Layout
                                        </a>
                                    </AuthorizeView>

                                    <AuthorizeView Policy="@Policies.ManageIssues">
                                        <a href="/issues/edit/@issue.IssueId" class="btn btn-outline-secondary" title="Edit Properties">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                        <a href="/issues/delete/@issue.IssueId" class="btn btn-outline-danger" title="Delete">
                                            <i class="bi bi-trash"></i> Delete
                                        </a>
                                    </AuthorizeView>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<Issue>? issues;

    protected override async Task OnInitializedAsync()
    {
        // Загружаем все выпуски
        issues = await IssueService.GetAllAsync();
    }

    private string GetStatusBadgeClass(IssueStatus status)
    {
        return status switch
        {
            IssueStatus.InProgress => "bg-secondary text-dark",
            IssueStatus.LayoutInProgress => "bg-info text-dark",
            IssueStatus.ReadyForPublish => "bg-success",
            IssueStatus.Published => "bg-primary",
            _ => "bg-secondary"
        };
    }
}
