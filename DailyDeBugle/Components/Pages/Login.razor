@page "/login"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using System.Security.Claims
@using DailyDeBugle.Services
@using DailyDeBugle.Models
@inject IUserService UserService
@inject NavigationManager Navigation
@layout Layout.MainLayout

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-4">
            <div class="card shadow">
                <div class="card-header bg-primary text-white text-center">
                    <h4>Вход в Daily DeBugle</h4>
                </div>
                <div class="card-body">
                    <EditForm Model="@loginModel" OnValidSubmit="HandleLogin" FormName="loginForm">
                        <DataAnnotationsValidator />
                        
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-danger">@errorMessage</div>
                        }

                        <div class="mb-3">
                            <label class="form-label">Имя пользователя</label>
                            <InputText @bind-Value="loginModel.Username" class="form-control" placeholder="Введите логин" />
                            <ValidationMessage For="@(() => loginModel.Username)" class="text-danger" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Пароль</label>
                            <InputText @bind-Value="loginModel.Password" type="password" class="form-control" placeholder="Введите пароль" />
                            <ValidationMessage For="@(() => loginModel.Password)" class="text-danger" />
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary" disabled="@isProcessing">
                                @(isProcessing ? "Вход..." : "Войти")
                            </button>
                        </div>
                    </EditForm>
                </div>
                <div class="card-footer text-center">
                    <p class="mb-0">Нет аккаунта? <a href="/register">Зарегистрироваться</a></p>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    private LoginModel loginModel = new();
    private string? errorMessage;
    private bool isProcessing;

    private async Task HandleLogin()
    {
        isProcessing = true;
        errorMessage = null;

        try
        {
            var user = await UserService.AuthenticateAsync(loginModel.Username!, loginModel.Password!);
            if (user != null)
            {
                // Перенаправляем на эндпоинт-хелпер для установки куки
                Navigation.NavigateTo($"/api/auth/signin?username={Uri.EscapeDataString(user.Username)}&returnUrl={Uri.EscapeDataString(ReturnUrl ?? "/")}", true);
            }
            else
            {
                errorMessage = "Неверное имя пользователя или пароль";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Произошла ошибка при входе. Попробуйте позже.";
        }
        finally
        {
            isProcessing = false;
        }
    }

    public class LoginModel
    {
        [Required(ErrorMessage = "Введите имя пользователя")]
        public string? Username { get; set; }

        [Required(ErrorMessage = "Введите пароль")]
        public string? Password { get; set; }
    }
}
