@page "/issues/{issueId:int}/read"
@attribute [Authorize(Policy = Policies.ViewContent)]
@using DailyDeBugle.Models
@using DailyDeBugle.Services
@using DailyDeBugle.Security
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@inject IIssueService IssueService
@inject IArticleService ArticleService
@inject ILayoutService LayoutService
@inject IGlobalTextStyleService TextStyleService
@inject IIssueCommentService IssueCommentService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IAuthorizationService AuthorizationService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>@currentIssue?.Publication?.Name - Issue #@currentIssue?.IssueNumber</PageTitle>

<div class="preview-container">
    <!-- Reader header -->
    <div class="preview-header mb-4">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h3>@currentIssue?.Publication?.Name - Issue #@currentIssue?.IssueNumber</h3>
                <p class="text-muted mb-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-calendar me-1" viewBox="0 0 16 16">
                        <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5zM1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4H1z"/>
                    </svg>
                    @currentIssue?.IssueDate.ToString("dd MMMM yyyy")
                </p>
            </div>
            <div>
                <a href="/" class="btn btn-outline-secondary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-house me-1" viewBox="0 0 16 16">
                        <path d="M8.707 1.5a1 1 0 0 0-1.414 0L.646 8.146a.5.5 0 0 0 .708.708L2 8.207V13.5A1.5 1.5 0 0 0 3.5 15h9a1.5 1.5 0 0 0 1.5-1.5V8.207l.646.647a.5.5 0 0 0 .708-.708L13 5.793V2.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v1.293L8.707 1.5ZM13 7.207V13.5a.5.5 0 0 1-.5.5h-9a.5.5 0 0 1-.5-.5V7.207l5-5 5 5Z"/>
                    </svg>
                    Home
                </a>
            </div>
        </div>
    </div>

    <!-- Page navigation -->
    <div class="mb-4">
        <div class="d-flex justify-content-between align-items-center">
            <div class="d-flex gap-2">
                <button class="btn btn-outline-secondary"
                        @onclick="PrevPage"
                        disabled="@(currentPageNumber <= 1)">
                    ← Previous
                </button>
                <button class="btn btn-outline-secondary" @onclick="NextPage"
                        disabled="@(currentPageNumber >= pageLayouts.Count)">
                    Next →
                </button>
            </div>
            <div>
                <h5 class="mb-0">
                    Page @currentPageNumber of @pageLayouts.Count
                    @if (currentPageLayout != null)
                    {
                        <span class="badge bg-info ms-2">@currentPageLayout.ColumnCount columns</span>
                    }
                </h5>
            </div>
            <div class="text-muted small">
                Size: A4 (42×29.7 cm)
            </div>
        </div>
    </div>

    <!-- Main reading container -->
    <div class="preview-content bg-light p-4 rounded d-flex justify-content-center"
         style="min-height: 800px; overflow: auto;">

        <!-- Newspaper container -->
        <div class="flow-container"
             style="
                width: 42cm;
                min-height: 29.7cm;
                background: white;
                box-shadow: 0 0 20px rgba(0,0,0,0.1);
                position: relative;
                padding: 2cm;
             ">

            @if (currentPageLayout != null)
            {
                <!-- Headers & Footers -->
                <div class="header-footer" style="position: absolute; top: 0.5cm; left: 0; right: 0; text-align: center; font-size: 10px; color: #666;">
                    Daily DeBugle • Issue #@currentIssue?.IssueNumber • @currentIssue?.IssueDate.ToString("dd.MM.yyyy")
                </div>

                <div class="header-footer" style="position: absolute; bottom: 0.5cm; left: 0; right: 0; text-align: center; font-size: 10px; color: #666;">
                    Page @currentPageNumber • Subscription index 12345
                </div>

                <!-- Main multi-column content -->
                <div class="multi-column-content"
                     style="
                         column-count: @currentPageLayout.ColumnCount;
                         column-gap: @(currentPageLayout.ColumnGap)cm;
                         column-fill: auto;
                         height: 25.7cm; /* Высота минус отступы */
                         font-family: @(currentTextStyle?.PrimaryFont ?? "'Times New Roman', serif");
                         font-size: @(currentTextStyle?.BodySize ?? 14)pt;
                         line-height: @(currentTextStyle?.BodyLineSpacing ?? 1.4);
                         word-wrap: break-word !important;
                         overflow-wrap: break-word !important;
                         word-break: break-word !important;
                         hyphens: auto;
                         -webkit-hyphens: auto;
                         -moz-hyphens: auto;
                         -ms-hyphens: auto;
                         overflow: hidden;
                         ">

                    <!-- Articles on this page -->
                    @{
                        var articlesOnPage = GetArticlesForPage(currentPageNumber);
                    }

                    @foreach (var article in articlesOnPage)
                    {
                        <!-- Статья -->
                        <div class="article-flow" style="break-inside: avoid; margin-bottom: 1cm;">
                            <h2 style="@GetHeadingStyle()">
                                @article.Headline
                                @if (article.ContinuedFromArticleId.HasValue)
                                {
                                    <span style="color: #999; font-size: 10px; margin-left: 0.5cm;">
                                        (continuation)
                                    </span>
                                }
                            </h2>

                            <div style="@GetMetaStyle()">
                                Author: @article.Author?.Username
                                @if (article.ContinuedOnArticleId.HasValue || article.ContinuedOnPage.HasValue)
                                {
                                    <span style="float: right; color: #999; font-size: 10px;">
                                        to be continued
                                    </span>
                                }
                            </div>

                            <div style="@GetContentStyle()">
                                @article.Content
                            </div>

                            @if (article.Images?.Any() == true)
                            {
                                <div class="article-images mt-3">
                                    @foreach (var img in article.Images.OrderBy(i => i.SortOrder).ThenBy(i => i.ArticleImageId))
                                    {
                                        <figure style="break-inside: avoid; margin: 0.5cm 0;">
                                            <img src="@img.ImagePath" alt="@img.Caption" style="max-width: 100%; height: auto; display: block; margin: 0 auto;" />
                                            @if (!string.IsNullOrWhiteSpace(img.Caption))
                                            {
                                                <figcaption style="font-size: 10px; color: #777; text-align: center; margin-top: 0.2cm;">
                                                    @img.Caption
                                                </figcaption>
                                            }
                                        </figure>
                                    }
                                </div>
                            }
                        </div>
                    }

                    <!-- Ad blocks -->
                    @{
                        var adsOnPage = GetAdsForPage(currentPageNumber);
                    }

                    @foreach (var ad in adsOnPage)
                    {
                        <div class="advertisement-flow" style="
                                break-inside: avoid;
                                margin: 1cm 0;
                                padding: 0.5cm;
                                background: #f9f9f9;
                                border: 1px solid #ddd;
                                border-radius: 3px;
                            ">
                            <div style="
                                    font-weight: bold;
                                    color: #d35400;
                                    font-size: 12px;
                                    margin-bottom: 0.3cm;
                                    text-align: center;
                                ">
                                ADVERTISEMENT
                            </div>

                            <div style="
                                    font-weight: bold;
                                    font-size: 14px;
                                    margin-bottom: 0.2cm;
                                    text-align: center;
                                ">
                                @ad.Advertiser
                            </div>

                            @if (ad.Type == AdType.Text)
                            {
                                <div style="
                                        font-size: 12px;
                                        color: #666;
                                        text-align: center;
                                    ">
                                    @ad.Content
                                </div>
                            }
                            else if (ad.Type == AdType.Image && !string.IsNullOrEmpty(ad.Content))
                            {
                                <div style="text-align: center; margin: 0.5cm 0;">
                                    <img src="@ad.Content" alt="@ad.Advertiser" 
                                         style="max-width: 100%; max-height: 5cm; object-fit: contain;" />
                                </div>
                            }

                            <div style="
                                    font-size: 10px;
                                    color: #888;
                                    margin-top: 0.3cm;
                                    text-align: center;
                                    font-style: italic;
                                ">
                                Valid from @ad.StartDate.ToString("dd.MM.yy") to @ad.EndDate.ToString("dd.MM.yy")
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="d-flex justify-content-center align-items-center h-100">
                    <div class="text-center text-muted">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-file-earmark" viewBox="0 0 16 16">
                            <path d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5L14 4.5zm-3 0A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V4.5h-2z"/>
                        </svg>
                        <h5 class="mt-3">This page is empty</h5>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Information panel -->
    <div class="row mt-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Page content @currentPageNumber</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <h6>Articles:</h6>
                            @{
                                var articlesList = GetArticlesForPage(currentPageNumber);
                            }

                            @if (articlesList.Any())
                            {
                                <ul class="list-unstyled">
                                    @foreach (var article in articlesList)
                                    {
                                        <li class="mb-2">
                                            <strong>@article.Headline</strong>
                                            <div class="small text-muted">@article.Author?.Username • @article.Status</div>
                                            @if (article.ContinuedFromArticleId.HasValue)
                                            {
                                                <div class="small text-info">↑ Article continuation</div>
                                            }
                                            @if (article.ContinuedOnArticleId.HasValue || article.ContinuedOnPage.HasValue)
                                            {
                                                <div class="small text-warning">↓ Has continuation</div>
                                            }
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <p class="text-muted">No articles on this page</p>
                            }
                        </div>
                        <div class="col-md-6">
                            <h6>Ad blocks:</h6>
                            @{
                                var adsList = GetAdsForPage(currentPageNumber);
                            }

                            @if (adsList.Any())
                            {
                                <ul class="list-unstyled">
                                    @foreach (var ad in adsList)
                                    {
                                        <li class="mb-2">
                                            <strong>@ad.Advertiser</strong>
                                            <div class="small text-muted">
                                                @if (ad.Type == AdType.Text)
                                                {
                                                    <span>Text advertisement</span>
                                                }
                                                else if (ad.Type == AdType.Image)
                                                {
                                                    <span>Image: @System.IO.Path.GetFileName(ad.Content)</span>
                                                }
                                            </div>
                                            <div class="small text-muted">Valid until @ad.EndDate.ToString("dd.MM.yyyy")</div>
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <p class="text-muted">No advertisements on this page</p>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (currentIssue?.Status == IssueStatus.Published)
{
    <div class="mt-4 card shadow-sm">
        <div class="card-body">
            <h4 class="card-title mb-3">Reader comments</h4>

            @if (canCommentOnIssue)
            {
                <div class="mb-4">
                    <label class="form-label" for="readerComment">Your comment</label>
                    <textarea id="readerComment"
                              class="form-control"
                              rows="3"
                              maxlength="2000"
                              @bind="newCommentText"
                              placeholder="Write what you think about this issue..."></textarea>
                    @if (!string.IsNullOrEmpty(commentError))
                    {
                        <div class="text-danger small mt-2">@commentError</div>
                    }
                    <button class="btn btn-primary mt-2"
                            disabled="@isSubmittingComment"
                            @onclick="SubmitCommentAsync">
                        @(isSubmittingComment ? "Sending..." : "Post comment")
                    </button>
                </div>
            }
            else if (!isAuthenticated)
            {
                <p class="text-muted">Log in to post a comment.</p>
            }

            @if (issueComments.Count == 0)
            {
                <p class="text-muted mb-0">No comments yet. Be the first!</p>
            }
            else
            {
                <ul class="list-unstyled mb-0">
                    @foreach (var comment in issueComments)
                    {
                        <li class="border-bottom py-3">
                            <div class="d-flex justify-content-between align-items-start mb-1">
                                <strong>@(comment.User?.Username ?? "Reader")</strong>
                                <span class="text-muted small">@comment.CreatedDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                            </div>
                            <p class="mb-0">@comment.Content</p>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>
}

@code {
    [Parameter]
    public int issueId { get; set; }

    private Issue currentIssue;
    private List<PageLayout> pageLayouts = new();
    private PageLayout currentPageLayout;
    private GlobalTextStyle currentTextStyle;
    private int currentPageNumber = 1;

    // Cached data
    private List<Article> allArticles = new();
    private List<AdvertisementBlock> allAds = new();

    private List<IssueComment> issueComments = new();
    private string newCommentText = string.Empty;
    private string? commentError;
    private bool isSubmittingComment;
    private bool canCommentOnIssue;
    private bool isAuthenticated;
    private int? currentUserId;

    protected override async Task OnInitializedAsync()
    {
        await LoadAuthStateAsync();
        await LoadData();
    }

    private async Task LoadAuthStateAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        isAuthenticated = user.Identity?.IsAuthenticated == true;

        if (isAuthenticated)
        {
            var authResult = await AuthorizationService.AuthorizeAsync(user, Policies.CommentOnPublishedIssues);
            canCommentOnIssue = authResult.Succeeded;

            var idClaim = user.FindFirst("UserId")?.Value;
            if (int.TryParse(idClaim, out var uid))
                currentUserId = uid;
        }
    }

    private async Task LoadData()
    {
        try
        {
            currentIssue = await IssueService.GetIssueAsync(issueId);

            if (currentIssue != null)
            {
                pageLayouts = await LayoutService.GetPageLayoutsForIssueAsync(issueId);
                allArticles = await ArticleService.GetArticlesByIssueAsync(issueId);
                
                // Загружаем стили типографики для выпуска
                currentTextStyle = await TextStyleService.GetStylesForIssueAsync(issueId);

                // Загружаем реальные рекламные блоки
                await LoadAdvertisementBlocks();

                await LoadCurrentPageLayout();

                if (currentIssue.Status == IssueStatus.Published)
                    await LoadCommentsAsync();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
        }
    }

    private async Task LoadCommentsAsync()
    {
        issueComments = await IssueCommentService.GetCommentsForIssueAsync(issueId);
    }

    private async Task SubmitCommentAsync()
    {
        commentError = null;

        if (!canCommentOnIssue || currentUserId == null)
        {
            commentError = "You cannot post comments to issues.";
            return;
        }

        if (currentIssue?.Status != IssueStatus.Published)
        {
            commentError = "Comments are only available for published issues.";
            return;
        }

        isSubmittingComment = true;
        try
        {
            await IssueCommentService.AddReaderCommentAsync(issueId, currentUserId.Value, newCommentText);
            newCommentText = string.Empty;
            await LoadCommentsAsync();
        }
        catch (Exception ex)
        {
            commentError = ex.Message;
        }
        finally
        {
            isSubmittingComment = false;
        }
    }

    private async Task LoadAdvertisementBlocks()
    {
        try
        {
            // Загружаем макеты страниц для получения размещенной рекламы
            var layouts = await LayoutService.GetPageLayoutsForIssueAsync(issueId);
            
            // Собираем все ID рекламных блоков, которые размещены в выпуске
            var adIds = new List<int>();
            foreach (var layout in layouts)
            {
                var layoutAdIds = layout.LayoutElements
                    .Where(le => le.AdvertisementBlockId.HasValue)
                    .Select(le => le.AdvertisementBlockId.Value)
                    .ToList();
                adIds.AddRange(layoutAdIds);
            }
            
            // Убираем дубликаты
            adIds = adIds.Distinct().ToList();
            
            // Загружаем рекламные блоки из базы данных
            allAds = new List<AdvertisementBlock>();
            foreach (var adId in adIds)
            {
                var layoutElements = await LayoutService.GetPageLayoutsForIssueAsync(issueId);
                var adElement = layoutElements
                    .SelectMany(l => l.LayoutElements)
                    .FirstOrDefault(le => le.AdvertisementBlockId == adId);
                
                if (adElement?.AdvertisementBlock != null)
                {
                    allAds.Add(adElement.AdvertisementBlock);
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading advertisements: {ex.Message}");
            allAds = new List<AdvertisementBlock>();
        }
    }

    private async Task LoadCurrentPageLayout()
    {
        currentPageLayout = pageLayouts.FirstOrDefault(p => p.PageNumber == currentPageNumber);
        StateHasChanged();
    }

    // Получаем статьи для конкретной страницы
    private List<Article> GetArticlesForPage(int pageNumber)
    {
        var layout = pageLayouts.FirstOrDefault(p => p.PageNumber == pageNumber);
        if (layout == null) return new List<Article>();

        var articleIds = layout.LayoutElements
            .Where(le => le.ArticleId.HasValue)
            .Select(le => le.ArticleId.Value)
            .ToList();

        return allArticles.Where(a => articleIds.Contains(a.ArticleId)).ToList();
    }

    // Получаем рекламу для конкретной страницы
    private List<AdvertisementBlock> GetAdsForPage(int pageNumber)
    {
        var layout = pageLayouts.FirstOrDefault(p => p.PageNumber == pageNumber);
        if (layout == null) return new List<AdvertisementBlock>();

        var adIds = layout.LayoutElements
            .Where(le => le.AdvertisementBlockId.HasValue)
            .Select(le => le.AdvertisementBlockId.Value)
            .ToList();

        return allAds.Where(ad => adIds.Contains(ad.AdvertisementBlockId)).ToList();
    }

    private async Task NextPage()
    {
        if (currentPageNumber < pageLayouts.Count)
        {
            currentPageNumber++;
            await LoadCurrentPageLayout();
        }
    }

    private async Task PrevPage()
    {
        if (currentPageNumber > 1)
        {
            currentPageNumber--;
            await LoadCurrentPageLayout();
        }
    }

    // Методы для получения стилей
    private string GetHeadingStyle()
    {
        var font = currentTextStyle?.HeadingFont ?? "Georgia, serif";
        var size = currentTextStyle?.H1Size ?? 24;
        var lineHeight = currentTextStyle?.HeadingLineSpacing ?? 1.2;
        
        return $"font-family: {font}; " +
               $"font-size: {size}pt; " +
               $"font-weight: bold; " +
               $"line-height: {lineHeight}; " +
               $"margin-bottom: 0.5cm; " +
               $"color: #333;";
    }

    private string GetMetaStyle()
    {
        var font = currentTextStyle?.PrimaryFont ?? "'Times New Roman', serif";
        var size = (currentTextStyle?.BodySize ?? 14) - 2;
        
        return $"font-family: {font}; " +
               $"font-style: italic; " +
               $"color: #666; " +
               $"margin-bottom: 0.5cm; " +
               $"font-size: {size}pt; " +
               $"border-bottom: 1px solid #eee; " +
               $"padding-bottom: 0.3cm;";
    }

    private string GetContentStyle()
    {
        var font = currentTextStyle?.PrimaryFont ?? "'Times New Roman', serif";
        var size = currentTextStyle?.BodySize ?? 14;
        var lineHeight = currentTextStyle?.BodyLineSpacing ?? 1.4;
    
        return $"font-family: {font}; " +
               $"font-size: {size}pt; " +
               $"line-height: {lineHeight}; " +
               $"text-align: justify; " +
               $"word-wrap: break-word !important; " +
               $"overflow-wrap: break-word !important; " +
               $"word-break: break-word !important; " +
               $"hyphens: auto; " +
               $"-webkit-hyphens: auto; " +
               $"-moz-hyphens: auto; " +
               $"-ms-hyphens: auto;";
    }
}